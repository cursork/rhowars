 TestAPIIntegration dummy;app;r;body;port;base;src;nl;payload;savedPath;tmpDir
‚çù Integration tests for the API using HttpCommand against a running server
 ‚éïIO‚Üê0
 ‚éïSE.SALT.Load'HttpCommand'
 ‚çù Use a temp directory for UserBots so tests never touch real uploads
 savedPath‚Üê##.Cfg.USER_BOTS_PATH
 tmpDir‚Üê(739‚å∂0),'/rhowars-test-bots'
 3 ‚éïMKDIR tmpDir
 ##.Cfg.USER_BOTS_PATH‚ÜêtmpDir
 port‚Üê18080+?100
 base‚Üê'http://localhost:',‚çïport
 app‚Üê‚éïNEW ##.Web.App (#.stark.Stark ##)
 app.Start port
 :Trap 0
     ‚çù --- GET /api/match before any match ‚Üí 404 ---
     r‚ÜêHttpCommand.Get base,'/api/match'
     Assert 'GET match empty ‚Üí 404' (404=r.HttpStatus)

     ‚çù --- GET /api/match/history before any match ‚Üí 404 ---
     r‚ÜêHttpCommand.Get base,'/api/match/history'
     Assert 'GET history empty ‚Üí 404' (404=r.HttpStatus)

     ‚çù --- POST /api/match with invalid bot ‚Üí 500 ---
     r‚ÜêHttpCommand.Do'POST'(base,'/api/match')'{"bots":["Spinner","NonExistent"]}'('content-type' 'application/json')
     Assert 'POST invalid bot ‚Üí 500' (500=r.HttpStatus)

     ‚çù --- POST /api/match ‚Üí 201 ---
     r‚ÜêHttpCommand.Do'POST'(base,'/api/match')'{"bots":["Spinner","RandomWalker"]}'('content-type' 'application/json')
     Assert 'POST match ‚Üí 201' (201=r.HttpStatus)
     body‚Üê‚éïJSON r.Data
     Assert 'response has done' (0‚âÝ‚éïNC'body.done')
     Assert 'response has names' (0‚âÝ‚éïNC'body.names')
     Assert 'response has turn' (0‚âÝ‚éïNC'body.turn')
     Assert 'response has hp' (0‚âÝ‚éïNC'body.hp')
     Assert 'response has alive' (0‚âÝ‚éïNC'body.alive')
     Assert 'match is done' (1=body.done)
     Assert '2 names' (2=‚â¢body.names)

     ‚çù --- GET /api/match ‚Üí 200 ---
     r‚ÜêHttpCommand.Get base,'/api/match'
     Assert 'GET match ‚Üí 200' (200=r.HttpStatus)
     body‚Üê‚éïJSON r.Data
     Assert 'GET match done' (1=body.done)

     ‚çù --- GET /api/match/history ‚Üí 200 with all fields ---
     r‚ÜêHttpCommand.Get base,'/api/match/history'
     Assert 'GET history ‚Üí 200' (200=r.HttpStatus)
     body‚Üê‚éïJSON r.Data
     Assert 'history has frames' (0<‚â¢body.frames)
     Assert 'history has turns' (body.turns>0)
     Assert 'history has arena' (##.Cfg.ARENA‚â°body.arena)
     Assert 'history has botRadius' (##.Cfg.BOT_RADIUS=body.botRadius)
     Assert 'history has visionRange' (##.Cfg.VISION_RANGE=body.visionRange)
     Assert 'history has visionHalfAngle' (##.Cfg.VISION_HALF_ANGLE=body.visionHalfAngle)
     Assert 'history has botHP' (##.Cfg.BOT_HP=body.botHP)
     Assert 'history has 2 names' (2=‚â¢body.names)
     Assert 'frame 0 turn is 0' (0=(‚äÉbody.frames).turn)
     Assert 'frame 0 has 2 bots' (2=‚â¢(‚äÉbody.frames).bots)
     Assert 'bot has 8 cols' (8=‚â¢‚äÉ(‚äÉbody.frames).bots)

     ‚çù --- POST /api/match with 3 bots ---
     r‚ÜêHttpCommand.Do'POST'(base,'/api/match')'{"bots":["Spinner","RandomWalker","Spinner"]}'('content-type' 'application/json')
     Assert 'POST 3 bots ‚Üí 201' (201=r.HttpStatus)
     body‚Üê‚éïJSON r.Data
     Assert '3 names' (3=‚â¢body.names)

     ‚çù ========== Bot CRUD tests ==========
     nl‚Üê‚éïUCS 10
     src‚Üê':Namespace TestBot',nl,'‚àá state‚ÜêInit',nl,'state‚Üê‚éïNS‚ç¨',nl,'‚àá',nl,'‚àá actions‚ÜêTick input',nl,'actions‚Üê‚éïNS‚ç¨',nl,'actions.state‚Üêinput.state',nl,'‚àá',nl,':EndNamespace'

     ‚çù --- GET /api/bots ‚Üí 200, has builtin ---
     r‚ÜêHttpCommand.Get base,'/api/bots'
     Assert 'GET bots ‚Üí 200' (200=r.HttpStatus)
     body‚Üê‚éïJSON r.Data
     Assert 'has builtin' (0‚âÝ‚éïNC'body.builtin')
     Assert 'has user' (0‚âÝ‚éïNC'body.user')
     Assert 'has builtin bots' (0<‚â¢body.builtin)

     ‚çù --- POST /api/bots with valid source ‚Üí 201 ---
     payload‚Üê‚éïJSON(author: 'testuser' ‚ãÑ name: 'TestBot' ‚ãÑ source: src)
     r‚ÜêHttpCommand.Do'POST'(base,'/api/bots')payload('content-type' 'application/json')
     Assert 'POST bot ‚Üí 201' (201=r.HttpStatus)
     body‚Üê‚éïJSON r.Data
     Assert 'not overwritten' (0=body.overwritten)
     Assert 'name matches' ('TestBot'‚â°body.name)

     ‚çù --- GET /api/bots ‚Üí user array has uploaded bot ---
     r‚ÜêHttpCommand.Get base,'/api/bots'
     body‚Üê‚éïJSON r.Data
     Assert 'user has 1 bot' (1=‚â¢body.user)
     Assert 'user bot name' ('TestBot'‚â°(‚äÉbody.user).name)
     Assert 'user bot author' ('testuser'‚â°(‚äÉbody.user).author)

     ‚çù --- POST /api/bots same name ‚Üí 201, overwritten ---
     r‚ÜêHttpCommand.Do'POST'(base,'/api/bots')payload('content-type' 'application/json')
     Assert 'POST bot overwrite ‚Üí 201' (201=r.HttpStatus)
     body‚Üê‚éïJSON r.Data
     Assert 'overwritten flag' (1=body.overwritten)

     ‚çù --- POST /api/bots with built-in name ‚Üí 400 ---
     src‚Üê':Namespace Spinner',nl,'‚àá state‚ÜêInit',nl,'state‚Üê‚éïNS‚ç¨',nl,'‚àá',nl,'‚àá actions‚ÜêTick input',nl,'actions‚Üê‚éïNS‚ç¨',nl,'‚àá',nl,':EndNamespace'
     payload‚Üê‚éïJSON(author: 'testuser' ‚ãÑ name: 'Spinner' ‚ãÑ source: src)
     r‚ÜêHttpCommand.Do'POST'(base,'/api/bots')payload('content-type' 'application/json')
     Assert 'POST builtin name ‚Üí 400' (400=r.HttpStatus)

     ‚çù --- POST /api/bots with invalid source ‚Üí 400 ---
     payload‚Üê‚éïJSON(author: 'testuser' ‚ãÑ name: 'BadBot' ‚ãÑ source: 'this is not valid APL')
     r‚ÜêHttpCommand.Do'POST'(base,'/api/bots')payload('content-type' 'application/json')
     Assert 'POST invalid source ‚Üí 400' (400=r.HttpStatus)

     ‚çù --- POST /api/match with user bot ‚Üí 201 ---
     payload‚Üê‚éïJSON(bots: 'Spinner' 'testuser/TestBot')
     r‚ÜêHttpCommand.Do'POST'(base,'/api/match')payload('content-type' 'application/json')
     Assert 'POST match with user bot ‚Üí 201' (201=r.HttpStatus)
     body‚Üê‚éïJSON r.Data
     Assert 'match done' (1=body.done)

     ‚çù --- DELETE /api/bots/testuser/TestBot ‚Üí 200 ---
     r‚ÜêHttpCommand.Do'DELETE'(base,'/api/bots/testuser/TestBot')'' ''
     Assert 'DELETE bot ‚Üí 200' (200=r.HttpStatus)
     body‚Üê‚éïJSON r.Data
     Assert 'deleted name' ('testuser/TestBot'‚â°body.deleted)

     ‚çù --- DELETE again ‚Üí 404 ---
     r‚ÜêHttpCommand.Do'DELETE'(base,'/api/bots/testuser/TestBot')'' ''
     Assert 'DELETE again ‚Üí 404' (404=r.HttpStatus)

     ‚çù --- GET /api/bots ‚Üí user array empty ---
     r‚ÜêHttpCommand.Get base,'/api/bots'
     body‚Üê‚éïJSON r.Data
     Assert 'user empty after delete' (0=‚â¢body.user)

     ‚çù ========== Record endpoint tests ==========

     ‚çù --- GET /api/match/record ‚Üí 200 ---
     r‚ÜêHttpCommand.Get base,'/api/match/record'
     Assert 'GET record ‚Üí 200' (200=r.HttpStatus)
     body‚Üê‚éïJSON r.Data
     Assert 'record has version' (0‚âÝ‚éïNC'body.version')
     Assert 'record has seed' (0‚âÝ‚éïNC'body.seed')
     Assert 'record has bots' (0‚âÝ‚éïNC'body.bots')
     Assert 'record has config' (0‚âÝ‚éïNC'body.config')
     Assert 'record has dyalog' (0‚âÝ‚éïNC'body.dyalog')

     ‚çù --- POST /api/match/replay ‚Üí 201 ---
     r‚ÜêHttpCommand.Do'POST'(base,'/api/match/replay')r.Data('content-type' 'application/json')
     Assert 'POST replay ‚Üí 201' (201=r.HttpStatus)
     body‚Üê‚éïJSON r.Data
     Assert 'replay has match' (0‚âÝ‚éïNC'body.match')
     Assert 'replay has warnings' (0‚âÝ‚éïNC'body.warnings')
     Assert 'replay match done' (1=body.match.done)

     ‚çù ========== Config endpoint tests ==========

     ‚çù --- GET /api/config ‚Üí 200, has all fields ---
     r‚ÜêHttpCommand.Get base,'/api/config'
     Assert 'GET config ‚Üí 200' (200=r.HttpStatus)
     body‚Üê‚éïJSON r.Data
     Assert 'config has arena' (0‚âÝ‚éïNC'body.arena')
     Assert 'config has botSpeed' (0‚âÝ‚éïNC'body.botSpeed')
     Assert 'config has collisionDamage' (0‚âÝ‚éïNC'body.collisionDamage')
     Assert 'config has collisionBounce' (0‚âÝ‚éïNC'body.collisionBounce')

     ‚çù --- POST /api/config/reset ‚Üí 200, returns config ---
     r‚ÜêHttpCommand.Do'POST'(base,'/api/config/reset')'' ''
     Assert 'POST config/reset ‚Üí 200' (200=r.HttpStatus)
     body‚Üê‚éïJSON r.Data
     Assert 'reset returns arena' (0‚âÝ‚éïNC'body.arena')

 :Else
     app.Stop
     ##.Cfg.USER_BOTS_PATH‚ÜêsavedPath
     3 ‚éïNDELETE tmpDir
     ‚éïDMX.EM ‚éïSIGNAL ‚éïDMX.EN
 :EndTrap
 app.Stop
 ##.Cfg.USER_BOTS_PATH‚ÜêsavedPath
 3 ‚éïNDELETE tmpDir
