 TestAPIIntegration dummy;app;r;body;port;base;src;nl;payload
‚ćĚ Integration tests for the API using HttpCommand against a running server
 ‚éēIO‚Üź0
 ‚éēSE.SALT.Load'HttpCommand'
 port‚Üź18080+?100
 base‚Üź'http://localhost:',‚ćēport
 app‚Üź‚éēNEW ##.Web.App (#.stark.Stark ##)
 app.Start port
 :Trap 0
     ‚ćĚ --- GET /api/match before any match ‚Üí 404 ---
     r‚ÜźHttpCommand.Get base,'/api/match'
     Assert 'GET match empty ‚Üí 404' (404=r.HttpStatus)

     ‚ćĚ --- GET /api/match/history before any match ‚Üí 404 ---
     r‚ÜźHttpCommand.Get base,'/api/match/history'
     Assert 'GET history empty ‚Üí 404' (404=r.HttpStatus)

     ‚ćĚ --- POST /api/match with invalid bot ‚Üí 500 ---
     r‚ÜźHttpCommand.Do'POST'(base,'/api/match')'{"bots":["Spinner","NonExistent"]}'('content-type' 'application/json')
     Assert 'POST invalid bot ‚Üí 500' (500=r.HttpStatus)

     ‚ćĚ --- POST /api/match ‚Üí 201 ---
     r‚ÜźHttpCommand.Do'POST'(base,'/api/match')'{"bots":["Spinner","RandomWalker"]}'('content-type' 'application/json')
     Assert 'POST match ‚Üí 201' (201=r.HttpStatus)
     body‚Üź‚éēJSON r.Data
     Assert 'response has done' (0‚Č†‚éēNC'body.done')
     Assert 'response has names' (0‚Č†‚éēNC'body.names')
     Assert 'response has turn' (0‚Č†‚éēNC'body.turn')
     Assert 'response has hp' (0‚Č†‚éēNC'body.hp')
     Assert 'response has alive' (0‚Č†‚éēNC'body.alive')
     Assert 'match is done' (1=body.done)
     Assert '2 names' (2=‚ČĘbody.names)

     ‚ćĚ --- GET /api/match ‚Üí 200 ---
     r‚ÜźHttpCommand.Get base,'/api/match'
     Assert 'GET match ‚Üí 200' (200=r.HttpStatus)
     body‚Üź‚éēJSON r.Data
     Assert 'GET match done' (1=body.done)

     ‚ćĚ --- GET /api/match/history ‚Üí 200 with all fields ---
     r‚ÜźHttpCommand.Get base,'/api/match/history'
     Assert 'GET history ‚Üí 200' (200=r.HttpStatus)
     body‚Üź‚éēJSON r.Data
     Assert 'history has frames' (0<‚ČĘbody.frames)
     Assert 'history has turns' (body.turns>0)
     Assert 'history has arena' (##.Cfg.ARENA‚Č°body.arena)
     Assert 'history has botRadius' (##.Cfg.BOT_RADIUS=body.botRadius)
     Assert 'history has visionRange' (##.Cfg.VISION_RANGE=body.visionRange)
     Assert 'history has visionHalfAngle' (##.Cfg.VISION_HALF_ANGLE=body.visionHalfAngle)
     Assert 'history has botHP' (##.Cfg.BOT_HP=body.botHP)
     Assert 'history has 2 names' (2=‚ČĘbody.names)
     Assert 'frame 0 turn is 0' (0=(‚äÉbody.frames).turn)
     Assert 'frame 0 has 2 bots' (2=‚ČĘ(‚äÉbody.frames).bots)
     Assert 'bot has 8 cols' (8=‚ČĘ‚äÉ(‚äÉbody.frames).bots)

     ‚ćĚ --- POST /api/match with 3 bots ---
     r‚ÜźHttpCommand.Do'POST'(base,'/api/match')'{"bots":["Spinner","RandomWalker","Spinner"]}'('content-type' 'application/json')
     Assert 'POST 3 bots ‚Üí 201' (201=r.HttpStatus)
     body‚Üź‚éēJSON r.Data
     Assert '3 names' (3=‚ČĘbody.names)

     ‚ćĚ ========== Bot CRUD tests ==========
     nl‚Üź‚éēUCS 10
     src‚Üź':Namespace TestBot',nl,'‚ąá state‚ÜźInit',nl,'state‚Üź‚éēNS‚ć¨',nl,'‚ąá',nl,'‚ąá actions‚ÜźTick input',nl,'actions‚Üź‚éēNS‚ć¨',nl,'actions.state‚Üźinput.state',nl,'‚ąá',nl,':EndNamespace'

     ‚ćĚ --- GET /api/bots ‚Üí 200, has builtin ---
     r‚ÜźHttpCommand.Get base,'/api/bots'
     Assert 'GET bots ‚Üí 200' (200=r.HttpStatus)
     body‚Üź‚éēJSON r.Data
     Assert 'has builtin' (0‚Č†‚éēNC'body.builtin')
     Assert 'has user' (0‚Č†‚éēNC'body.user')
     Assert 'has builtin bots' (0<‚ČĘbody.builtin)

     ‚ćĚ --- POST /api/bots with valid source ‚Üí 201 ---
     payload‚Üź‚éēJSON(author: 'testuser' ‚čĄ name: 'TestBot' ‚čĄ source: src)
     r‚ÜźHttpCommand.Do'POST'(base,'/api/bots')payload('content-type' 'application/json')
     Assert 'POST bot ‚Üí 201' (201=r.HttpStatus)
     body‚Üź‚éēJSON r.Data
     Assert 'not overwritten' (0=body.overwritten)
     Assert 'name matches' ('TestBot'‚Č°body.name)

     ‚ćĚ --- GET /api/bots ‚Üí user array has uploaded bot ---
     r‚ÜźHttpCommand.Get base,'/api/bots'
     body‚Üź‚éēJSON r.Data
     Assert 'user has 1 bot' (1=‚ČĘbody.user)
     Assert 'user bot name' ('TestBot'‚Č°(‚äÉbody.user).name)
     Assert 'user bot author' ('testuser'‚Č°(‚äÉbody.user).author)

     ‚ćĚ --- POST /api/bots same name ‚Üí 201, overwritten ---
     r‚ÜźHttpCommand.Do'POST'(base,'/api/bots')payload('content-type' 'application/json')
     Assert 'POST bot overwrite ‚Üí 201' (201=r.HttpStatus)
     body‚Üź‚éēJSON r.Data
     Assert 'overwritten flag' (1=body.overwritten)

     ‚ćĚ --- POST /api/bots with built-in name ‚Üí 400 ---
     src‚Üź':Namespace Spinner',nl,'‚ąá state‚ÜźInit',nl,'state‚Üź‚éēNS‚ć¨',nl,'‚ąá',nl,'‚ąá actions‚ÜźTick input',nl,'actions‚Üź‚éēNS‚ć¨',nl,'‚ąá',nl,':EndNamespace'
     payload‚Üź‚éēJSON(author: 'testuser' ‚čĄ name: 'Spinner' ‚čĄ source: src)
     r‚ÜźHttpCommand.Do'POST'(base,'/api/bots')payload('content-type' 'application/json')
     Assert 'POST builtin name ‚Üí 400' (400=r.HttpStatus)

     ‚ćĚ --- POST /api/bots with invalid source ‚Üí 400 ---
     payload‚Üź‚éēJSON(author: 'testuser' ‚čĄ name: 'BadBot' ‚čĄ source: 'this is not valid APL')
     r‚ÜźHttpCommand.Do'POST'(base,'/api/bots')payload('content-type' 'application/json')
     Assert 'POST invalid source ‚Üí 400' (400=r.HttpStatus)

     ‚ćĚ --- POST /api/match with user bot ‚Üí 201 ---
     payload‚Üź‚éēJSON(bots: 'Spinner' 'testuser/TestBot')
     r‚ÜźHttpCommand.Do'POST'(base,'/api/match')payload('content-type' 'application/json')
     Assert 'POST match with user bot ‚Üí 201' (201=r.HttpStatus)
     body‚Üź‚éēJSON r.Data
     Assert 'match done' (1=body.done)

     ‚ćĚ --- DELETE /api/bots/testuser/TestBot ‚Üí 200 ---
     r‚ÜźHttpCommand.Do'DELETE'(base,'/api/bots/testuser/TestBot')'' ''
     Assert 'DELETE bot ‚Üí 200' (200=r.HttpStatus)
     body‚Üź‚éēJSON r.Data
     Assert 'deleted name' ('testuser/TestBot'‚Č°body.deleted)

     ‚ćĚ --- DELETE again ‚Üí 404 ---
     r‚ÜźHttpCommand.Do'DELETE'(base,'/api/bots/testuser/TestBot')'' ''
     Assert 'DELETE again ‚Üí 404' (404=r.HttpStatus)

     ‚ćĚ --- GET /api/bots ‚Üí user array empty ---
     r‚ÜźHttpCommand.Get base,'/api/bots'
     body‚Üź‚éēJSON r.Data
     Assert 'user empty after delete' (0=‚ČĘbody.user)

 :Else
     app.Stop
     ‚éēDMX.EM ‚éēSIGNAL ‚éēDMX.EN
 :EndTrap
 ‚ćĚ Cleanup test bot files on success
 :Trap 0
     ‚éēNDELETE'UserBots/testuser/TestBot.apln'
     ‚éēNDELETE'UserBots/testuser/TestBot.json'
 :Else
 :EndTrap
 app.Stop
