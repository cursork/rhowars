:Class App
тНЭ rhowars web API тАФ Stark-based REST server
тНЭ
тНЭ   appтЖРтОХNEW rw.Web.App (StarkClass gameNS)
тНЭ   app.Start 8080

    :Field Private router
    :Field Private lastMatch
    :Field Private lastBotNames
    :Field Private game
    :Field Private defaultCfg
    :Field Private matches
    :Field Private nextMatchId
    :Field Private remotes
    :Field Private nextSlot

    тИЗ Make args;StarkClass
      :Access Public
      :Implements Constructor
      (StarkClass game)тЖРargs
      lastMatchтЖРтНм
      lastBotNamesтЖРтНм
      matchesтЖРтНм
      nextMatchIdтЖР1
      remotesтЖРтНм
      nextSlotтЖР0
      routerтЖРтОХNEW StarkClass
      router.HandlersтЖРтОХTHIS
      router.InfoтЖР(title: 'rhowars' тЛД version: '0.1.0')
      defaultCfgтЖРSaveCfg
      game.BotLib.LoadAll
      '/api/match/list' router.Get 'ListMatches'
      '/api/match/{id}/history' router.Get 'GetMatchHistory'
      '/api/match/record' router.Get 'GetRecord'
      '/api/match/replay' router.Post 'ReplayRecord'
      '/api/match/history' router.Get 'GetHistory'
      '/api/match' router.Post 'StartMatch'
      '/api/match' router.Get 'GetMatch'
      '/api/bots' router.Get 'ListBots'
      '/api/bots' router.Post 'UploadBot'
      '/api/bots/{author}/{name}' router.Delete 'DeleteBot'
      '/api/config' router.Get 'GetConfig'
      '/api/config/reset' router.Post 'ResetConfig'
      '/api/remote/list' router.Get 'ListRemotes'
      '/api/remote/{slot}/{token}/state' router.Get 'GetRemoteState'
      '/api/remote/{slot}/{token}/action' router.Post 'PostRemoteAction'
    тИЗ

    тИЗ Start port
      :Access Public
      router.Start port
    тИЗ

    тИЗ Stop
      :Access Public
      router.Stop
    тИЗ

    тИЗ resultтЖРStartMatch req;body;names;botns;i;ns;rec;matchRemotes
      :Access Public
      тОХIOтЖР0
      :Trap 0
          bodyтЖРreq.Payload
          namesтЖРbody.bots
          тНЭ Apply ephemeral config if provided (persists until server restart)
          :If 0тЙатОХNC'body.config'
              ApplyCfg body.config
          :EndIf
          botnsтЖРтНм
          matchRemotesтЖРтНм
          :For i :In тН│тЙвnames
              :If 'Remote'тЙбiтКГnames
                  nsтЖРgame.Rhobots.Remote.Create nextSlot
                  ns.botIndexтЖРi
                  remotes,тЖРns
                  matchRemotes,тЖРns
                  nextSlotтЖРnextSlot+1
              :Else
                  nsтЖРgame.BotLib.Resolve(iтКГnames)
              :EndIf
              botns,тЖРns
          :EndFor
          lastBotNamesтЖРnames
          recтЖРNewMatchRecord names
          :If 0<тЙвmatchRemotes
              lastMatchтЖРтНм
              RunRemoteMatch&(botns rec matchRemotes)
              req.SetStatus 202
              resultтЖРтОХNSтНм
              result.idтЖРrec.id
              result.statusтЖР'running'
              result.remotesтЖР{тОХIOтЖР0 тЛД nsтЖРтОХNSтНм тЛД ns.slotтЖРтН╡.slot тЛД ns.tokenтЖРтН╡.secret тЛД ns}┬иmatchRemotes
          :Else
              lastMatchтЖРgame.Engine.Run botns
              rec.matchтЖРlastMatch
              rec.doneтЖР1
              req.SetStatus 201
              resultтЖРMatchSummary lastMatch
              result.idтЖРrec.id
          :EndIf
      :Else
          req.Fail 500
          resultтЖР(error: тОХDMX.Message тЛД at: тОХDMX.DM)
      :EndTrap
    тИЗ

    тИЗ resultтЖРGetMatch req
      :Access Public
      тОХIOтЖР0
      :If тНмтЙбlastMatch
          req.Fail 404
          resultтЖР(detail: 'No match has been run yet')
      :Else
          resultтЖРMatchSummary lastMatch
      :EndIf
    тИЗ

    тИЗ resultтЖРGetHistory req;h;frames;s;f
      :Access Public
      тОХIOтЖР0
      :If тНмтЙбlastMatch
          req.Fail 404
          resultтЖР(detail: 'No match has been run yet')
      :Else
          framesтЖР{(turn: тН╡.turn тЛД bots: тН╡.bots тЛД bullets: тН╡.bullets)}┬иlastMatch.history
          resultтЖР(
            turns: lastMatch.turn
            done: lastMatch.done
            names: lastMatch.names
            arena: game.Cfg.ARENA
            botRadius: game.Cfg.BOT_RADIUS
            visionRange: game.Cfg.VISION_RANGE
            visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
            botHP: game.Cfg.BOT_HP
            frames: frames
          )
      :EndIf
    тИЗ

    тИЗ resultтЖРListBots req
      :Access Public
      resultтЖРgame.BotLib.List
    тИЗ

    тИЗ resultтЖРUploadBot req;body;author;name;source;avatar
      :Access Public
      тОХIOтЖР0
      :Trap 0
          bodyтЖРreq.Payload
          authorтЖРbody.author
          nameтЖРbody.name
          sourceтЖРbody.source
          avatarтЖР''
          :If 0тЙатОХNC'body.avatar'
              avatarтЖРbody.avatar
          :EndIf
          resultтЖРgame.BotLib.Upload author name source avatar
          req.SetStatus 201
      :Else
          req.Fail 400
          resultтЖР(error: тОХDMX.Message)
      :EndTrap
    тИЗ

    тИЗ resultтЖРDeleteBot req;author;name
      :Access Public
      тОХIOтЖР0
      :Trap 6
          authorтЖРreq.PathParams.author
          nameтЖРreq.PathParams.name
          game.BotLib.Delete author name
          resultтЖР(deleted: author,'/',name)
      :Else
          req.Fail 404
          resultтЖР(error: тОХDMX.Message)
      :EndTrap
    тИЗ

    тИЗ resultтЖРMatchSummary m;a;h
      :Access Private
      тОХIOтЖР0
      aтЖРm.bots[;7] тЛД hтЖРm.bots[;5]
      resultтЖР(
        turn: m.turn
        done: m.done
        names: m.names
        alive: a
        hp: h
        turns: тЙвm.history
      )
    тИЗ

    тИЗ resultтЖРGetConfig req
      :Access Public
      resultтЖР(
        arena: game.Cfg.ARENA
        botSpeed: game.Cfg.BOT_SPEED
        botHP: game.Cfg.BOT_HP
        botRadius: game.Cfg.BOT_RADIUS
        bulletSpeed: game.Cfg.BULLET_SPEED
        bulletDamage: game.Cfg.BULLET_DAMAGE
        visionRange: game.Cfg.VISION_RANGE
        visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
        cooldown: game.Cfg.COOLDOWN
        collisionDamage: game.Cfg.COLLISION_DAMAGE
        collisionBounce: game.Cfg.COLLISION_BOUNCE
        maxTurns: game.Cfg.MAX_TURNS
      )
    тИЗ

    тИЗ savedтЖРSaveCfg
      :Access Private
      savedтЖР(
        ARENA: game.Cfg.ARENA
        BOT_SPEED: game.Cfg.BOT_SPEED
        BOT_HP: game.Cfg.BOT_HP
        BOT_RADIUS: game.Cfg.BOT_RADIUS
        BULLET_SPEED: game.Cfg.BULLET_SPEED
        BULLET_DAMAGE: game.Cfg.BULLET_DAMAGE
        VISION_RANGE: game.Cfg.VISION_RANGE
        VISION_HALF_ANGLE: game.Cfg.VISION_HALF_ANGLE
        COOLDOWN: game.Cfg.COOLDOWN
        COLLISION_DAMAGE: game.Cfg.COLLISION_DAMAGE
        COLLISION_BOUNCE: game.Cfg.COLLISION_BOUNCE
        MAX_TURNS: game.Cfg.MAX_TURNS
      )
    тИЗ

    тИЗ {r}тЖРApplyCfg cfg
      :Access Private
      rтЖРтНм
      :If 0тЙатОХNC'cfg.arena'          тЛД game.Cfg.ARENAтЖРcfg.arena                       тЛД :EndIf
      :If 0тЙатОХNC'cfg.botSpeed'       тЛД game.Cfg.BOT_SPEEDтЖРcfg.botSpeed                тЛД :EndIf
      :If 0тЙатОХNC'cfg.botHP'          тЛД game.Cfg.BOT_HPтЖРcfg.botHP                      тЛД :EndIf
      :If 0тЙатОХNC'cfg.botRadius'      тЛД game.Cfg.BOT_RADIUSтЖРcfg.botRadius              тЛД :EndIf
      :If 0тЙатОХNC'cfg.bulletSpeed'    тЛД game.Cfg.BULLET_SPEEDтЖРcfg.bulletSpeed           тЛД :EndIf
      :If 0тЙатОХNC'cfg.bulletDamage'   тЛД game.Cfg.BULLET_DAMAGEтЖРcfg.bulletDamage         тЛД :EndIf
      :If 0тЙатОХNC'cfg.visionRange'    тЛД game.Cfg.VISION_RANGEтЖРcfg.visionRange           тЛД :EndIf
      :If 0тЙатОХNC'cfg.visionHalfAngle' тЛД game.Cfg.VISION_HALF_ANGLEтЖРcfg.visionHalfAngle тЛД :EndIf
      :If 0тЙатОХNC'cfg.cooldown'       тЛД game.Cfg.COOLDOWNтЖРcfg.cooldown                  тЛД :EndIf
      :If 0тЙатОХNC'cfg.collisionDamage' тЛД game.Cfg.COLLISION_DAMAGEтЖРcfg.collisionDamage  тЛД :EndIf
      :If 0тЙатОХNC'cfg.collisionBounce' тЛД game.Cfg.COLLISION_BOUNCEтЖРcfg.collisionBounce  тЛД :EndIf
      :If 0тЙатОХNC'cfg.maxTurns'       тЛД game.Cfg.MAX_TURNSтЖРcfg.maxTurns                 тЛД :EndIf
    тИЗ

    тИЗ resultтЖРResetConfig req
      :Access Public
      RestoreCfg defaultCfg
      resultтЖРGetConfig req
    тИЗ

    тИЗ {r}тЖРRestoreCfg saved
      :Access Private
      rтЖРтНм
      game.Cfg.ARENAтЖРsaved.ARENA
      game.Cfg.BOT_SPEEDтЖРsaved.BOT_SPEED
      game.Cfg.BOT_HPтЖРsaved.BOT_HP
      game.Cfg.BOT_RADIUSтЖРsaved.BOT_RADIUS
      game.Cfg.BULLET_SPEEDтЖРsaved.BULLET_SPEED
      game.Cfg.BULLET_DAMAGEтЖРsaved.BULLET_DAMAGE
      game.Cfg.VISION_RANGEтЖРsaved.VISION_RANGE
      game.Cfg.VISION_HALF_ANGLEтЖРsaved.VISION_HALF_ANGLE
      game.Cfg.COOLDOWNтЖРsaved.COOLDOWN
      game.Cfg.COLLISION_DAMAGEтЖРsaved.COLLISION_DAMAGE
      game.Cfg.COLLISION_BOUNCEтЖРsaved.COLLISION_BOUNCE
      game.Cfg.MAX_TURNSтЖРsaved.MAX_TURNS
    тИЗ

    тИЗ resultтЖРGetRecord req
      :Access Public
      тОХIOтЖР0
      :If тНмтЙбlastMatch
          req.Fail 404
          resultтЖР(detail: 'No match has been run yet')
      :Else
          resultтЖРgame.Record.Create lastMatch lastBotNames
      :EndIf
    тИЗ

    тИЗ resultтЖРReplayRecord req;body;manifest;names;botns;i;ns;warnings;savedCfg;cfg
      :Access Public
      тОХIOтЖР0
      :Trap 0
          bodyтЖРreq.Payload
          manifestтЖРbody
          тНЭ Validate manifest
          warningsтЖРgame.Record.Validate manifest
          тНЭ Save current config and apply manifest config
          savedCfgтЖРSaveCfg
          :Trap 0
              cfgтЖРmanifest.config
              :If 0тЙатОХNC'cfg.ARENA'             тЛД game.Cfg.ARENAтЖРcfg.ARENA                         тЛД :EndIf
              :If 0тЙатОХNC'cfg.BOT_SPEED'         тЛД game.Cfg.BOT_SPEEDтЖРcfg.BOT_SPEED                 тЛД :EndIf
              :If 0тЙатОХNC'cfg.BOT_HP'            тЛД game.Cfg.BOT_HPтЖРcfg.BOT_HP                       тЛД :EndIf
              :If 0тЙатОХNC'cfg.BOT_RADIUS'        тЛД game.Cfg.BOT_RADIUSтЖРcfg.BOT_RADIUS               тЛД :EndIf
              :If 0тЙатОХNC'cfg.BULLET_SPEED'      тЛД game.Cfg.BULLET_SPEEDтЖРcfg.BULLET_SPEED           тЛД :EndIf
              :If 0тЙатОХNC'cfg.BULLET_DAMAGE'     тЛД game.Cfg.BULLET_DAMAGEтЖРcfg.BULLET_DAMAGE         тЛД :EndIf
              :If 0тЙатОХNC'cfg.VISION_RANGE'      тЛД game.Cfg.VISION_RANGEтЖРcfg.VISION_RANGE           тЛД :EndIf
              :If 0тЙатОХNC'cfg.VISION_HALF_ANGLE' тЛД game.Cfg.VISION_HALF_ANGLEтЖРcfg.VISION_HALF_ANGLE тЛД :EndIf
              :If 0тЙатОХNC'cfg.COOLDOWN'          тЛД game.Cfg.COOLDOWNтЖРcfg.COOLDOWN                   тЛД :EndIf
              :If 0тЙатОХNC'cfg.COLLISION_DAMAGE'  тЛД game.Cfg.COLLISION_DAMAGEтЖРcfg.COLLISION_DAMAGE    тЛД :EndIf
              :If 0тЙатОХNC'cfg.COLLISION_BOUNCE'  тЛД game.Cfg.COLLISION_BOUNCEтЖРcfg.COLLISION_BOUNCE    тЛД :EndIf
              :If 0тЙатОХNC'cfg.MAX_TURNS'         тЛД game.Cfg.MAX_TURNSтЖРcfg.MAX_TURNS                 тЛД :EndIf
              тНЭ Resolve bots
              namesтЖР{тН╡.name}┬иmanifest.bots
              botnsтЖРтНм
              :For i :In тН│тЙвnames
                  nsтЖРgame.BotLib.Resolve(iтКГnames)
                  botns,тЖРns
              :EndFor
              lastBotNamesтЖРnames
              lastMatchтЖРmanifest.seed game.Engine.Run botns
              req.SetStatus 201
              resultтЖР(match: MatchSummary lastMatch тЛД warnings: warnings)
          :Else
              RestoreCfg savedCfg
              тОХDMX.EM тОХSIGNAL тОХDMX.EN
          :EndTrap
      :Else
          req.Fail 500
          resultтЖР(error: тОХDMX.Message)
      :EndTrap
    тИЗ

    тИЗ {r}тЖРRunRemoteMatch args;botns;rec;matchRemotes;rem
      :Access Private
      rтЖРтНм
      (botns rec matchRemotes)тЖРargs
      :Trap 0
          lastMatchтЖРgame.Engine.Run botns
          rec.matchтЖРlastMatch
      :Else
          тНЭ Match failed тАФ ensure we don't hang
      :EndTrap
      rec.doneтЖР1
      :For rem :In matchRemotes
          :If 0тЙатОХNC'lastMatch.bots'
              rem.finalHPтЖРlastMatch.bots[rem.botIndex;5]
              rem.aliveтЖРlastMatch.bots[rem.botIndex;7]
          :EndIf
          rem.statusтЖР'done'
      :EndFor
    тИЗ

    тИЗ recтЖРNewMatchRecord names
      :Access Private
      recтЖРтОХNSтНм
      rec.idтЖРnextMatchId
      rec.namesтЖРnames
      rec.matchтЖРтНм
      rec.doneтЖР0
      matches,тЖРrec
      nextMatchIdтЖРnextMatchId+1
    тИЗ

    тИЗ resultтЖРListMatches req
      :Access Public
      тОХIOтЖР0
      resultтЖР(matches: {тОХIOтЖР0 тЛД nsтЖРтОХNSтНм тЛД ns.idтЖРтН╡.id тЛД ns.namesтЖРтН╡.names тЛД ns.doneтЖРтН╡.done тЛД ns.turnsтЖР{тНмтЙбтН╡:0 тЛД тН╡.turn}тН╡.match тЛД ns}┬иmatches)
    тИЗ

    тИЗ resultтЖРGetMatchHistory req;id;valid;vals;idx;rec;frames
      :Access Public
      тОХIOтЖР0
      (valid vals)тЖРтОХVFI req.PathParams.id
      :If ~тИи/valid
          req.Fail 400
          resultтЖР(detail: 'Invalid match ID')
          :Return
      :EndIf
      idтЖРтКГvalid/vals
      idxтЖР{тН╡.id}┬иmatches
      :If ~idтИКidx
          req.Fail 404
          resultтЖР(detail: 'Match not found')
          :Return
      :EndIf
      recтЖР(idxтН│id)тКГmatches
      :If тНмтЙбrec.match
          :If ~rec.done
              resultтЖР(detail: 'Match not yet started' тЛД id: id)
          :Else
              req.Fail 500
              resultтЖР(detail: 'Match failed')
          :EndIf
          :Return
      :EndIf
      framesтЖР{(turn: тН╡.turn тЛД bots: тН╡.bots тЛД bullets: тН╡.bullets)}┬иrec.match.history
      resultтЖР(
        turns: rec.match.turn
        done: rec.match.done
        names: rec.match.names
        arena: game.Cfg.ARENA
        botRadius: game.Cfg.BOT_RADIUS
        visionRange: game.Cfg.VISION_RANGE
        visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
        botHP: game.Cfg.BOT_HP
        frames: frames
      )
    тИЗ

    тИЗ remтЖРResolveSlot(slot token);valid;vals;idx
      :Access Private
      тОХIOтЖР0
      (valid vals)тЖРтОХVFIтНХslot
      :If ~тИи/valid
          remтЖРтНм
          :Return
      :EndIf
      slotтЖРтКГvalid/vals
      idxтЖР{тН╡.slot}┬иremotes
      :If ~slotтИКidx
          remтЖРтНм
          :Return
      :EndIf
      remтЖР(idxтН│slot)тКГremotes
      :If tokenтЙвrem.secret
          remтЖРтНм
      :EndIf
    тИЗ

    тИЗ resultтЖРListRemotes req
      :Access Public
      тОХIOтЖР0
      resultтЖР(remotes: {тОХIOтЖР0 тЛД nsтЖРтОХNSтНм тЛД ns.slotтЖРтН╡.slot тЛД ns.statusтЖРтН╡.status тЛД ns.tickтЖРтН╡.tick тЛД ns}┬иremotes)
    тИЗ

    тИЗ resultтЖРGetRemoteState req;rem;input;vis
      :Access Public
      тОХIOтЖР0
      remтЖРResolveSlot req.PathParams.slot req.PathParams.token
      :If тНмтЙбrem
          req.Fail 404
          resultтЖР(detail: 'Remote slot not found')
          :Return
      :EndIf
      :Select rem.status
      :Case 'idle'
          req.Fail 404
          resultтЖР(detail: 'Remote not yet started')
      :Case 'done'
          resultтЖР(status: 'done' тЛД turn: rem.tick тЛД hp: rem.finalHP тЛД alive: rem.alive)
      :Case 'processing'
          resultтЖР(status: 'processing' тЛД turn: rem.tick)
      :Case 'waiting'
          inputтЖРrem.pendingInput
          resultтЖРтОХNSтНм
          result.statusтЖР'active'
          result.turnтЖРinput.turn
          result.positionтЖРinput.loc
          result.directionтЖРinput.direction
          result.turretтЖРinput.turret
          result.hpтЖРinput.hp
          result.arenaтЖРinput.arena
          result.configтЖРinput.cfg
          visтЖРinput.visible
          :If 0<тЙвvis
              result.visibleтЖР{nsтЖРтОХNSтНм тЛД ns.typeтЖР(тН╡[2])тКГ'rhobot' 'bullet' тЛД ns.distanceтЖРтН╡[0] тЛД ns.offsetтЖРтН╡[1] тЛД ns}┬итЖУvis
          :Else
              result.visibleтЖРтНм
          :EndIf
      :EndSelect
    тИЗ

    тИЗ resultтЖРPostRemoteAction req;body;act;rem
      :Access Public
      тОХIOтЖР0
      remтЖРResolveSlot req.PathParams.slot req.PathParams.token
      :If тНмтЙбrem
          req.Fail 404
          resultтЖР(detail: 'Remote slot not found')
          :Return
      :EndIf
      :If 'waiting'тЙвrem.status
          :If 'done'тЙбrem.status
              resultтЖР(status: 'done' тЛД turn: rem.tick)
          :Else
              req.Fail 409
              resultтЖР(detail: 'Remote bot is not waiting for input')
          :EndIf
          :Return
      :EndIf
      bodyтЖРreq.Payload
      actтЖРтОХNSтНм
      :If 0тЙаbody.тОХNC'direction' тЛД act.directionтЖРbody.direction тЛД :EndIf
      :If 0тЙаbody.тОХNC'turret' тЛД act.turretтЖРbody.turret тЛД :EndIf
      :If 0тЙаbody.тОХNC'fire' тЛД act.fireтЖРbody.fire тЛД :EndIf
      :If 0тЙаbody.тОХNC'speed' тЛД act.speedтЖРbody.speed тЛД :EndIf
      act.stateтЖРrem.pendingInput.state
      rem.pendingActionтЖРact
      тОХTPUT rem.token
      resultтЖР(ok: 1 тЛД turn: rem.tick)
    тИЗ

:EndClass
