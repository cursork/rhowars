    ‚àá result‚ÜêStartMatch req;body;names;botns;i;ns;rec;matchRemotes
      :Access Public
      ‚éïIO‚Üê0
      :Trap 0
          body‚Üêreq.Payload
          names‚Üêbody.bots
          ‚çù Apply ephemeral config if provided (persists until server restart)
          :If 0‚âÝ‚éïNC'body.config'
              ApplyCfg body.config
          :EndIf
          botns‚Üê‚ç¨
          matchRemotes‚Üê‚ç¨
          :For i :In ‚ç≥‚â¢names
              :If 'Remote'‚â°6‚Üëi‚äÉnames
                  ns‚Üêgame.Rhobots.Remote.Create nextSlot
                  ns.botIndex‚Üêi
                  ‚çù Support Remote:Name format for display
                  :If ':'‚àäi‚äÉnames
                      ns.‚éïDF(1+(':'‚ç≥‚ç®i‚äÉnames))‚Üìi‚äÉnames
                  :EndIf
                  remotes,‚Üêns
                  matchRemotes,‚Üêns
                  nextSlot‚ÜênextSlot+1
              :Else
                  ns‚Üêgame.BotLib.Resolve(i‚äÉnames)
              :EndIf
              botns,‚Üêns
          :EndFor
          lastBotNames‚Üênames
          rec‚ÜêNewMatchRecord names
          RunMatch&(botns rec matchRemotes)
          req.SetStatus 202
          result‚Üê‚éïNS‚ç¨
          result.id‚Üêrec.id
          result.status‚Üê'running'
          :If 0<‚â¢matchRemotes
              result.remotes‚Üê{‚éïIO‚Üê0 ‚ãÑ ns‚Üê‚éïNS‚ç¨ ‚ãÑ ns.slot‚Üê‚çµ.slot ‚ãÑ ns.token‚Üê‚çµ.secret ‚ãÑ ns}¬®matchRemotes
          :EndIf
      :Else
          req.Fail 500
          result‚Üê(error: ‚éïDMX.Message ‚ãÑ at: ‚éïDMX.DM)
      :EndTrap
    ‚àá

    ‚àá result‚ÜêGetMatch req
      :Access Public
      ‚éïIO‚Üê0
      :If ‚ç¨‚â°lastMatch
          req.Fail 404
          result‚Üê(detail: 'No match has been run yet')
      :Else
          result‚ÜêMatchSummary lastMatch
      :EndIf
    ‚àá

    ‚àá result‚ÜêGetHistory req;h;frames;s;f
      :Access Public
      ‚éïIO‚Üê0
      :If ‚ç¨‚â°lastMatch
          req.Fail 404
          result‚Üê(detail: 'No match has been run yet')
      :Else
          frames‚Üê{(turn: ‚çµ.turn ‚ãÑ bots: ‚çµ.bots ‚ãÑ bullets: ‚çµ.bullets ‚ãÑ thoughts: {6::‚ç¨ ‚ãÑ ‚çµ.thoughts}‚çµ)}¬®lastMatch.history
          result‚Üê(
            turns: lastMatch.turn
            done: lastMatch.done
            names: lastMatch.names
            arena: game.Cfg.ARENA
            botRadius: game.Cfg.BOT_RADIUS
            visionRange: game.Cfg.VISION_RANGE
            visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
            botHP: game.Cfg.BOT_HP
            frames: frames
          )
      :EndIf
    ‚àá

    ‚àá result‚ÜêListBots req
      :Access Public
      result‚Üêgame.BotLib.List
    ‚àá

    ‚àá result‚ÜêUploadBot req;body;author;name;source;avatar
      :Access Public
      ‚éïIO‚Üê0
      :Trap 0
          body‚Üêreq.Payload
          author‚Üêbody.author
          name‚Üêbody.name
          source‚Üêbody.source
          avatar‚Üê''
          :If 0‚âÝ‚éïNC'body.avatar'
              avatar‚Üêbody.avatar
          :EndIf
          result‚Üêgame.BotLib.Upload author name source avatar
          req.SetStatus 201
      :Else
          req.Fail 400
          result‚Üê(error: ‚éïDMX.Message)
      :EndTrap
    ‚àá

    ‚àá result‚ÜêDeleteBot req;author;name
      :Access Public
      ‚éïIO‚Üê0
      :Trap 6
          author‚Üêreq.PathParams.author
          name‚Üêreq.PathParams.name
          game.BotLib.Delete author name
          result‚Üê(deleted: author,'/',name)
      :Else
          req.Fail 404
          result‚Üê(error: ‚éïDMX.Message)
      :EndTrap
    ‚àá

    ‚àá result‚ÜêMatchSummary m;a;h
      :Access Private
      ‚éïIO‚Üê0
      a‚Üêm.bots[;7] ‚ãÑ h‚Üêm.bots[;5]
      result‚Üê(
        turn: m.turn
        done: m.done
        names: m.names
        alive: a
        hp: h
        turns: ‚â¢m.history
      )
