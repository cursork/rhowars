    ‚ąá result‚ÜźListRemotes req
      :Access Public
      ‚éēIO‚Üź0
      result‚Üź(remotes: {‚éēIO‚Üź0 ‚čĄ ns‚Üź‚éēNS‚ć¨ ‚čĄ ns.slot‚Üź‚ćĶ.slot ‚čĄ ns.status‚Üź‚ćĶ.status ‚čĄ ns.tick‚Üź‚ćĶ.tick ‚čĄ ns}¬®remotes)
    ‚ąá

    ‚ąá result‚ÜźGetRemoteState req;rem;input;vis
      :Access Public
      ‚éēIO‚Üź0
      rem‚ÜźResolveSlot req.PathParams.slot req.PathParams.token
      :If ‚ć¨‚Č°rem
          req.Fail 404
          result‚Üź(detail: 'Remote slot not found')
          :Return
      :EndIf
      :Select rem.status
      :Case 'idle'
          req.Fail 404
          result‚Üź(detail: 'Remote not yet started')
      :Case 'done'
          result‚Üź‚éēNS‚ć¨
          result.status‚Üź'done'
          result.turn‚Üźrem.tick
          result.hp‚Üźrem.finalHP
          result.alive‚Üźrem.alive
          result.rank‚Üźrem.rank
          result.totalBots‚Üźrem.totalBots
          :If ¬Į1‚ČĘrem.deathTurn
              result.deathTurn‚Üźrem.deathTurn
          :EndIf
          :If 0‚Č†rem.‚éēNC'standings'
              result.standings‚Üźrem.standings
          :EndIf
          :If 0‚Č†rem.‚éēNC'shotsHit'
              result.shotsHit‚Üźrem.shotsHit
              result.kills‚Üźrem.kills
              result.damageTaken‚Üźrem.damageTaken
          :EndIf
      :Case 'processing'
          result‚Üź(status: 'processing' ‚čĄ turn: rem.tick)
      :Case 'waiting'
          input‚Üźrem.pendingInput
          result‚Üź‚éēNS‚ć¨
          result.status‚Üź'active'
          result.turn‚Üźinput.turn
          result.position‚Üźinput.loc
          result.direction‚Üźinput.direction
          result.turret‚Üźinput.turret
          result.hp‚Üźinput.hp
          result.arena‚Üźinput.arena
          result.config‚Üźinput.cfg
          vis‚Üźinput.visible
          :If 0<‚ČĘvis
              result.visible‚Üź{ns‚Üź‚éēNS‚ć¨ ‚čĄ ns.type‚Üź(‚ćĶ[2])‚äÉ'rhobot' 'bullet' ‚čĄ ns.distance‚Üź‚ćĶ[0] ‚čĄ ns.offset‚Üź‚ćĶ[1] ‚čĄ ns}¬®‚Üďvis
          :Else
              result.visible‚Üź‚ć¨
          :EndIf
      :EndSelect
    ‚ąá

    ‚ąá result‚ÜźPostRemoteAction req;body;act;rem
      :Access Public
      ‚éēIO‚Üź0
      rem‚ÜźResolveSlot req.PathParams.slot req.PathParams.token
      :If ‚ć¨‚Č°rem
          req.Fail 404
          result‚Üź(detail: 'Remote slot not found')
          :Return
      :EndIf
      :If 'waiting'‚ČĘrem.status
          :If 'done'‚Č°rem.status
              result‚Üź(status: 'done' ‚čĄ turn: rem.tick)
          :Else
              req.Fail 409
              result‚Üź(detail: 'Remote bot is not waiting for input')
          :EndIf
          :Return
      :EndIf
      body‚Üźreq.Payload
      act‚Üź‚éēNS‚ć¨
      :If 0‚Č†body.‚éēNC'direction' ‚čĄ act.direction‚Üźbody.direction ‚čĄ :EndIf
      :If 0‚Č†body.‚éēNC'turret' ‚čĄ act.turret‚Üźbody.turret ‚čĄ :EndIf
      :If 0‚Č†body.‚éēNC'fire' ‚čĄ act.fire‚Üźbody.fire ‚čĄ :EndIf
      :If 0‚Č†body.‚éēNC'speed' ‚čĄ act.speed‚Üźbody.speed ‚čĄ :EndIf
      :If 0‚Č†body.‚éēNC'thought' ‚čĄ act.thought‚Üźbody.thought ‚čĄ :EndIf
      act.state‚Üźrem.pendingInput.state
      rem.pendingAction‚Üźact
      ‚éēTPUT rem.token
      result‚Üź(ok: 1 ‚čĄ turn: rem.tick)
    ‚ąá

:EndClass
