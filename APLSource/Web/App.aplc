:Class App
‚ćĚ rhowars web API ‚ÄĒ Stark-based REST server
‚ćĚ
‚ćĚ   app‚Üź‚éēNEW rw.Web.App (StarkClass gameNS)
‚ćĚ   app.Start 8080

    :Field Private router
    :Field Private lastMatch
    :Field Private game
    :Field Private defaultCfg

    ‚ąá Make args;StarkClass
      :Access Public
      :Implements Constructor
      (StarkClass game)‚Üźargs
      lastMatch‚Üź‚ć¨
      router‚Üź‚éēNEW StarkClass
      router.Handlers‚Üź‚éēTHIS
      router.Info‚Üź(title: 'rhowars' ‚čĄ version: '0.1.0')
      defaultCfg‚ÜźSaveCfg
      game.BotLib.LoadAll
      '/api/match' router.Post 'StartMatch'
      '/api/match' router.Get 'GetMatch'
      '/api/match/history' router.Get 'GetHistory'
      '/api/bots' router.Get 'ListBots'
      '/api/bots' router.Post 'UploadBot'
      '/api/bots/{author}/{name}' router.Delete 'DeleteBot'
      '/api/config' router.Get 'GetConfig'
      '/api/config/reset' router.Post 'ResetConfig'
    ‚ąá

    ‚ąá Start port
      :Access Public
      router.Start port
    ‚ąá

    ‚ąá Stop
      :Access Public
      router.Stop
    ‚ąá

    ‚ąá result‚ÜźStartMatch req;body;names;botns;i;ns
      :Access Public
      ‚éēIO‚Üź0
      :Trap 0
          body‚Üźreq.Payload
          names‚Üźbody.bots
          ‚ćĚ Apply ephemeral config if provided (persists until server restart)
          :If 0‚Č†‚éēNC'body.config'
              ApplyCfg body.config
          :EndIf
          botns‚Üź‚ć¨
          :For i :In ‚ć≥‚ČĘnames
              ns‚Üźgame.BotLib.Resolve(i‚äÉnames)
              botns,‚Üźns
          :EndFor
          lastMatch‚Üźgame.Engine.Run botns
          req.SetStatus 201
          result‚ÜźMatchSummary lastMatch
      :Else
          req.Fail 500
          result‚Üź(error: ‚éēDMX.Message ‚čĄ at: ‚éēDMX.DM)
      :EndTrap
    ‚ąá

    ‚ąá result‚ÜźGetMatch req
      :Access Public
      ‚éēIO‚Üź0
      :If ‚ć¨‚Č°lastMatch
          req.Fail 404
          result‚Üź(detail: 'No match has been run yet')
      :Else
          result‚ÜźMatchSummary lastMatch
      :EndIf
    ‚ąá

    ‚ąá result‚ÜźGetHistory req;h;frames;s;f
      :Access Public
      ‚éēIO‚Üź0
      :If ‚ć¨‚Č°lastMatch
          req.Fail 404
          result‚Üź(detail: 'No match has been run yet')
      :Else
          frames‚Üź{(turn: ‚ćĶ.turn ‚čĄ bots: ‚ćĶ.bots ‚čĄ bullets: ‚ćĶ.bullets)}¬®lastMatch.history
          result‚Üź(
            turns: lastMatch.turn
            done: lastMatch.done
            names: lastMatch.names
            arena: game.Cfg.ARENA
            botRadius: game.Cfg.BOT_RADIUS
            visionRange: game.Cfg.VISION_RANGE
            visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
            botHP: game.Cfg.BOT_HP
            frames: frames
          )
      :EndIf
    ‚ąá

    ‚ąá result‚ÜźListBots req
      :Access Public
      result‚Üźgame.BotLib.List
    ‚ąá

    ‚ąá result‚ÜźUploadBot req;body;author;name;source;avatar
      :Access Public
      ‚éēIO‚Üź0
      :Trap 0
          body‚Üźreq.Payload
          author‚Üźbody.author
          name‚Üźbody.name
          source‚Üźbody.source
          avatar‚Üź''
          :If 0‚Č†‚éēNC'body.avatar'
              avatar‚Üźbody.avatar
          :EndIf
          result‚Üźgame.BotLib.Upload author name source avatar
          req.SetStatus 201
      :Else
          req.Fail 400
          result‚Üź(error: ‚éēDMX.Message)
      :EndTrap
    ‚ąá

    ‚ąá result‚ÜźDeleteBot req;author;name
      :Access Public
      ‚éēIO‚Üź0
      :Trap 6
          author‚Üźreq.PathParams.author
          name‚Üźreq.PathParams.name
          game.BotLib.Delete author name
          result‚Üź(deleted: author,'/',name)
      :Else
          req.Fail 404
          result‚Üź(error: ‚éēDMX.Message)
      :EndTrap
    ‚ąá

    ‚ąá result‚ÜźMatchSummary m;a;h
      :Access Private
      ‚éēIO‚Üź0
      a‚Üźm.bots[;7] ‚čĄ h‚Üźm.bots[;5]
      result‚Üź(
        turn: m.turn
        done: m.done
        names: m.names
        alive: a
        hp: h
        turns: ‚ČĘm.history
      )
    ‚ąá

    ‚ąá result‚ÜźGetConfig req
      :Access Public
      result‚Üź(
        arena: game.Cfg.ARENA
        botSpeed: game.Cfg.BOT_SPEED
        botHP: game.Cfg.BOT_HP
        botRadius: game.Cfg.BOT_RADIUS
        bulletSpeed: game.Cfg.BULLET_SPEED
        bulletDamage: game.Cfg.BULLET_DAMAGE
        visionRange: game.Cfg.VISION_RANGE
        visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
        cooldown: game.Cfg.COOLDOWN
        maxTurns: game.Cfg.MAX_TURNS
      )
    ‚ąá

    ‚ąá saved‚ÜźSaveCfg
      :Access Private
      saved‚Üź(
        ARENA: game.Cfg.ARENA
        BOT_SPEED: game.Cfg.BOT_SPEED
        BOT_HP: game.Cfg.BOT_HP
        BOT_RADIUS: game.Cfg.BOT_RADIUS
        BULLET_SPEED: game.Cfg.BULLET_SPEED
        BULLET_DAMAGE: game.Cfg.BULLET_DAMAGE
        VISION_RANGE: game.Cfg.VISION_RANGE
        VISION_HALF_ANGLE: game.Cfg.VISION_HALF_ANGLE
        COOLDOWN: game.Cfg.COOLDOWN
        MAX_TURNS: game.Cfg.MAX_TURNS
      )
    ‚ąá

    ‚ąá ApplyCfg cfg
      :Access Private
      :If 0‚Č†‚éēNC'cfg.arena'          ‚čĄ game.Cfg.ARENA‚Üźcfg.arena                       ‚čĄ :EndIf
      :If 0‚Č†‚éēNC'cfg.botSpeed'       ‚čĄ game.Cfg.BOT_SPEED‚Üźcfg.botSpeed                ‚čĄ :EndIf
      :If 0‚Č†‚éēNC'cfg.botHP'          ‚čĄ game.Cfg.BOT_HP‚Üźcfg.botHP                      ‚čĄ :EndIf
      :If 0‚Č†‚éēNC'cfg.botRadius'      ‚čĄ game.Cfg.BOT_RADIUS‚Üźcfg.botRadius              ‚čĄ :EndIf
      :If 0‚Č†‚éēNC'cfg.bulletSpeed'    ‚čĄ game.Cfg.BULLET_SPEED‚Üźcfg.bulletSpeed           ‚čĄ :EndIf
      :If 0‚Č†‚éēNC'cfg.bulletDamage'   ‚čĄ game.Cfg.BULLET_DAMAGE‚Üźcfg.bulletDamage         ‚čĄ :EndIf
      :If 0‚Č†‚éēNC'cfg.visionRange'    ‚čĄ game.Cfg.VISION_RANGE‚Üźcfg.visionRange           ‚čĄ :EndIf
      :If 0‚Č†‚éēNC'cfg.visionHalfAngle' ‚čĄ game.Cfg.VISION_HALF_ANGLE‚Üźcfg.visionHalfAngle ‚čĄ :EndIf
      :If 0‚Č†‚éēNC'cfg.cooldown'       ‚čĄ game.Cfg.COOLDOWN‚Üźcfg.cooldown                  ‚čĄ :EndIf
      :If 0‚Č†‚éēNC'cfg.maxTurns'       ‚čĄ game.Cfg.MAX_TURNS‚Üźcfg.maxTurns                 ‚čĄ :EndIf
    ‚ąá

    ‚ąá result‚ÜźResetConfig req
      :Access Public
      RestoreCfg defaultCfg
      result‚ÜźGetConfig req
    ‚ąá

    ‚ąá RestoreCfg saved
      :Access Private
      game.Cfg.ARENA‚Üźsaved.ARENA
      game.Cfg.BOT_SPEED‚Üźsaved.BOT_SPEED
      game.Cfg.BOT_HP‚Üźsaved.BOT_HP
      game.Cfg.BOT_RADIUS‚Üźsaved.BOT_RADIUS
      game.Cfg.BULLET_SPEED‚Üźsaved.BULLET_SPEED
      game.Cfg.BULLET_DAMAGE‚Üźsaved.BULLET_DAMAGE
      game.Cfg.VISION_RANGE‚Üźsaved.VISION_RANGE
      game.Cfg.VISION_HALF_ANGLE‚Üźsaved.VISION_HALF_ANGLE
      game.Cfg.COOLDOWN‚Üźsaved.COOLDOWN
      game.Cfg.MAX_TURNS‚Üźsaved.MAX_TURNS
    ‚ąá

:EndClass
