:Class App
вЌќ rhowars web API вЂ” Stark-based REST server
вЌќ
вЌќ   appв†ђвЋ•NEW rw.Web.App (StarkClass gameNS)
вЌќ   app.Start 8080

    :Field Private router
    :Field Private lastMatch
    :Field Private lastBotNames
    :Field Private game
    :Field Private defaultCfg
    :Field Private matches
    :Field Private nextMatchId
    :Field Private remotes
    :Field Private nextSlot

    в€‡ Make args;StarkClass
      :Access Public
      :Implements Constructor
      (StarkClass game)в†ђargs
      lastMatchв†ђвЌ¬
      lastBotNamesв†ђвЌ¬
      matchesв†ђвЌ¬
      nextMatchIdв†ђ1
      remotesв†ђвЌ¬
      nextSlotв†ђ0
      routerв†ђвЋ•NEW StarkClass
      router.Handlersв†ђвЋ•THIS
      router.Infoв†ђ(title: 'rhowars' в‹„ version: '0.1.0')
      defaultCfgв†ђSaveCfg
      game.BotLib.LoadAll
      '/api/match/list' router.Get 'ListMatches'
      '/api/match/{id}/history' router.Get 'GetMatchHistory'
      '/api/match/record' router.Get 'GetRecord'
      '/api/match/replay' router.Post 'ReplayRecord'
      '/api/match/history' router.Get 'GetHistory'
      '/api/match' router.Post 'StartMatch'
      '/api/match' router.Get 'GetMatch'
      '/api/bots' router.Get 'ListBots'
      '/api/bots' router.Post 'UploadBot'
      '/api/bots/{author}/{name}' router.Delete 'DeleteBot'
      '/api/config' router.Get 'GetConfig'
      '/api/config/reset' router.Post 'ResetConfig'
      '/api/remote/list' router.Get 'ListRemotes'
      '/api/remote/{slot}/{token}/state' router.Get 'GetRemoteState'
      '/api/remote/{slot}/{token}/action' router.Post 'PostRemoteAction'
    в€‡

    в€‡ Start port
      :Access Public
      router.Start port
    в€‡

    в€‡ Stop
      :Access Public
      router.Stop
    в€‡

    в€‡ resultв†ђStartMatch req;body;names;botns;i;ns;rec;matchRemotes
      :Access Public
      вЋ•IOв†ђ0
      :Trap 0
          bodyв†ђreq.Payload
          namesв†ђbody.bots
          вЌќ Apply ephemeral config if provided (persists until server restart)
          :If 0в‰ вЋ•NC'body.config'
              ApplyCfg body.config
          :EndIf
          botnsв†ђвЌ¬
          matchRemotesв†ђвЌ¬
          :For i :In вЌів‰ўnames
              :If 'Remote'в‰ЎiвЉѓnames
                  nsв†ђgame.Rhobots.Remote.Create nextSlot
                  ns.botIndexв†ђi
                  remotes,в†ђns
                  matchRemotes,в†ђns
                  nextSlotв†ђnextSlot+1
              :Else
                  nsв†ђgame.BotLib.Resolve(iвЉѓnames)
              :EndIf
              botns,в†ђns
          :EndFor
          lastBotNamesв†ђnames
          recв†ђNewMatchRecord names
          :If 0<в‰ўmatchRemotes
              lastMatchв†ђвЌ¬
              RunRemoteMatch&(botns rec matchRemotes)
              req.SetStatus 202
              resultв†ђвЋ•NSвЌ¬
              result.idв†ђrec.id
              result.statusв†ђ'running'
              result.remotesв†ђ{вЋ•IOв†ђ0 в‹„ nsв†ђвЋ•NSвЌ¬ в‹„ ns.slotв†ђвЌµ.slot в‹„ ns.tokenв†ђвЌµ.secret в‹„ ns}ВЁmatchRemotes
          :Else
              lastMatchв†ђgame.Engine.Run botns
              rec.matchв†ђlastMatch
              rec.doneв†ђ1
              req.SetStatus 201
              resultв†ђMatchSummary lastMatch
              result.idв†ђrec.id
          :EndIf
      :Else
          req.Fail 500
          resultв†ђ(error: вЋ•DMX.Message в‹„ at: вЋ•DMX.DM)
      :EndTrap
    в€‡

    в€‡ resultв†ђGetMatch req
      :Access Public
      вЋ•IOв†ђ0
      :If вЌ¬в‰ЎlastMatch
          req.Fail 404
          resultв†ђ(detail: 'No match has been run yet')
      :Else
          resultв†ђMatchSummary lastMatch
      :EndIf
    в€‡

    в€‡ resultв†ђGetHistory req;h;frames;s;f
      :Access Public
      вЋ•IOв†ђ0
      :If вЌ¬в‰ЎlastMatch
          req.Fail 404
          resultв†ђ(detail: 'No match has been run yet')
      :Else
          framesв†ђ{(turn: вЌµ.turn в‹„ bots: вЌµ.bots в‹„ bullets: вЌµ.bullets)}ВЁlastMatch.history
          resultв†ђ(
            turns: lastMatch.turn
            done: lastMatch.done
            names: lastMatch.names
            arena: game.Cfg.ARENA
            botRadius: game.Cfg.BOT_RADIUS
            visionRange: game.Cfg.VISION_RANGE
            visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
            botHP: game.Cfg.BOT_HP
            frames: frames
          )
      :EndIf
    в€‡

    в€‡ resultв†ђListBots req
      :Access Public
      resultв†ђgame.BotLib.List
    в€‡

    в€‡ resultв†ђUploadBot req;body;author;name;source;avatar
      :Access Public
      вЋ•IOв†ђ0
      :Trap 0
          bodyв†ђreq.Payload
          authorв†ђbody.author
          nameв†ђbody.name
          sourceв†ђbody.source
          avatarв†ђ''
          :If 0в‰ вЋ•NC'body.avatar'
              avatarв†ђbody.avatar
          :EndIf
          resultв†ђgame.BotLib.Upload author name source avatar
          req.SetStatus 201
      :Else
          req.Fail 400
          resultв†ђ(error: вЋ•DMX.Message)
      :EndTrap
    в€‡

    в€‡ resultв†ђDeleteBot req;author;name
      :Access Public
      вЋ•IOв†ђ0
      :Trap 6
          authorв†ђreq.PathParams.author
          nameв†ђreq.PathParams.name
          game.BotLib.Delete author name
          resultв†ђ(deleted: author,'/',name)
      :Else
          req.Fail 404
          resultв†ђ(error: вЋ•DMX.Message)
      :EndTrap
    в€‡

    в€‡ resultв†ђMatchSummary m;a;h
      :Access Private
      вЋ•IOв†ђ0
      aв†ђm.bots[;7] в‹„ hв†ђm.bots[;5]
      resultв†ђ(
        turn: m.turn
        done: m.done
        names: m.names
        alive: a
        hp: h
        turns: в‰ўm.history
      )
    в€‡

    в€‡ resultв†ђGetConfig req
      :Access Public
      resultв†ђ(
        arena: game.Cfg.ARENA
        botSpeed: game.Cfg.BOT_SPEED
        botHP: game.Cfg.BOT_HP
        botRadius: game.Cfg.BOT_RADIUS
        bulletSpeed: game.Cfg.BULLET_SPEED
        bulletDamage: game.Cfg.BULLET_DAMAGE
        visionRange: game.Cfg.VISION_RANGE
        visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
        cooldown: game.Cfg.COOLDOWN
        collisionDamage: game.Cfg.COLLISION_DAMAGE
        collisionBounce: game.Cfg.COLLISION_BOUNCE
        maxTurns: game.Cfg.MAX_TURNS
      )
    в€‡

    в€‡ savedв†ђSaveCfg
      :Access Private
      savedв†ђ(
        ARENA: game.Cfg.ARENA
        BOT_SPEED: game.Cfg.BOT_SPEED
        BOT_HP: game.Cfg.BOT_HP
        BOT_RADIUS: game.Cfg.BOT_RADIUS
        BULLET_SPEED: game.Cfg.BULLET_SPEED
        BULLET_DAMAGE: game.Cfg.BULLET_DAMAGE
        VISION_RANGE: game.Cfg.VISION_RANGE
        VISION_HALF_ANGLE: game.Cfg.VISION_HALF_ANGLE
        COOLDOWN: game.Cfg.COOLDOWN
        COLLISION_DAMAGE: game.Cfg.COLLISION_DAMAGE
        COLLISION_BOUNCE: game.Cfg.COLLISION_BOUNCE
        MAX_TURNS: game.Cfg.MAX_TURNS
      )
    в€‡

    в€‡ {r}в†ђApplyCfg cfg
      :Access Private
      rв†ђвЌ¬
      :If 0в‰ вЋ•NC'cfg.arena'          в‹„ game.Cfg.ARENAв†ђcfg.arena                       в‹„ :EndIf
      :If 0в‰ вЋ•NC'cfg.botSpeed'       в‹„ game.Cfg.BOT_SPEEDв†ђcfg.botSpeed                в‹„ :EndIf
      :If 0в‰ вЋ•NC'cfg.botHP'          в‹„ game.Cfg.BOT_HPв†ђcfg.botHP                      в‹„ :EndIf
      :If 0в‰ вЋ•NC'cfg.botRadius'      в‹„ game.Cfg.BOT_RADIUSв†ђcfg.botRadius              в‹„ :EndIf
      :If 0в‰ вЋ•NC'cfg.bulletSpeed'    в‹„ game.Cfg.BULLET_SPEEDв†ђcfg.bulletSpeed           в‹„ :EndIf
      :If 0в‰ вЋ•NC'cfg.bulletDamage'   в‹„ game.Cfg.BULLET_DAMAGEв†ђcfg.bulletDamage         в‹„ :EndIf
      :If 0в‰ вЋ•NC'cfg.visionRange'    в‹„ game.Cfg.VISION_RANGEв†ђcfg.visionRange           в‹„ :EndIf
      :If 0в‰ вЋ•NC'cfg.visionHalfAngle' в‹„ game.Cfg.VISION_HALF_ANGLEв†ђcfg.visionHalfAngle в‹„ :EndIf
      :If 0в‰ вЋ•NC'cfg.cooldown'       в‹„ game.Cfg.COOLDOWNв†ђcfg.cooldown                  в‹„ :EndIf
      :If 0в‰ вЋ•NC'cfg.collisionDamage' в‹„ game.Cfg.COLLISION_DAMAGEв†ђcfg.collisionDamage  в‹„ :EndIf
      :If 0в‰ вЋ•NC'cfg.collisionBounce' в‹„ game.Cfg.COLLISION_BOUNCEв†ђcfg.collisionBounce  в‹„ :EndIf
      :If 0в‰ вЋ•NC'cfg.maxTurns'       в‹„ game.Cfg.MAX_TURNSв†ђcfg.maxTurns                 в‹„ :EndIf
    в€‡

    в€‡ resultв†ђResetConfig req
      :Access Public
      RestoreCfg defaultCfg
      resultв†ђGetConfig req
    в€‡

    в€‡ {r}в†ђRestoreCfg saved
      :Access Private
      rв†ђвЌ¬
      game.Cfg.ARENAв†ђsaved.ARENA
      game.Cfg.BOT_SPEEDв†ђsaved.BOT_SPEED
      game.Cfg.BOT_HPв†ђsaved.BOT_HP
      game.Cfg.BOT_RADIUSв†ђsaved.BOT_RADIUS
      game.Cfg.BULLET_SPEEDв†ђsaved.BULLET_SPEED
      game.Cfg.BULLET_DAMAGEв†ђsaved.BULLET_DAMAGE
      game.Cfg.VISION_RANGEв†ђsaved.VISION_RANGE
      game.Cfg.VISION_HALF_ANGLEв†ђsaved.VISION_HALF_ANGLE
      game.Cfg.COOLDOWNв†ђsaved.COOLDOWN
      game.Cfg.COLLISION_DAMAGEв†ђsaved.COLLISION_DAMAGE
      game.Cfg.COLLISION_BOUNCEв†ђsaved.COLLISION_BOUNCE
      game.Cfg.MAX_TURNSв†ђsaved.MAX_TURNS
    в€‡

    в€‡ resultв†ђGetRecord req
      :Access Public
      вЋ•IOв†ђ0
      :If вЌ¬в‰ЎlastMatch
          req.Fail 404
          resultв†ђ(detail: 'No match has been run yet')
      :Else
          resultв†ђgame.Record.Create lastMatch lastBotNames
      :EndIf
    в€‡

    в€‡ resultв†ђReplayRecord req;body;manifest;names;botns;i;ns;warnings;savedCfg;cfg
      :Access Public
      вЋ•IOв†ђ0
      :Trap 0
          bodyв†ђreq.Payload
          manifestв†ђbody
          вЌќ Validate manifest
          warningsв†ђgame.Record.Validate manifest
          вЌќ Save current config and apply manifest config
          savedCfgв†ђSaveCfg
          :Trap 0
              cfgв†ђmanifest.config
              :If 0в‰ вЋ•NC'cfg.ARENA'             в‹„ game.Cfg.ARENAв†ђcfg.ARENA                         в‹„ :EndIf
              :If 0в‰ вЋ•NC'cfg.BOT_SPEED'         в‹„ game.Cfg.BOT_SPEEDв†ђcfg.BOT_SPEED                 в‹„ :EndIf
              :If 0в‰ вЋ•NC'cfg.BOT_HP'            в‹„ game.Cfg.BOT_HPв†ђcfg.BOT_HP                       в‹„ :EndIf
              :If 0в‰ вЋ•NC'cfg.BOT_RADIUS'        в‹„ game.Cfg.BOT_RADIUSв†ђcfg.BOT_RADIUS               в‹„ :EndIf
              :If 0в‰ вЋ•NC'cfg.BULLET_SPEED'      в‹„ game.Cfg.BULLET_SPEEDв†ђcfg.BULLET_SPEED           в‹„ :EndIf
              :If 0в‰ вЋ•NC'cfg.BULLET_DAMAGE'     в‹„ game.Cfg.BULLET_DAMAGEв†ђcfg.BULLET_DAMAGE         в‹„ :EndIf
              :If 0в‰ вЋ•NC'cfg.VISION_RANGE'      в‹„ game.Cfg.VISION_RANGEв†ђcfg.VISION_RANGE           в‹„ :EndIf
              :If 0в‰ вЋ•NC'cfg.VISION_HALF_ANGLE' в‹„ game.Cfg.VISION_HALF_ANGLEв†ђcfg.VISION_HALF_ANGLE в‹„ :EndIf
              :If 0в‰ вЋ•NC'cfg.COOLDOWN'          в‹„ game.Cfg.COOLDOWNв†ђcfg.COOLDOWN                   в‹„ :EndIf
              :If 0в‰ вЋ•NC'cfg.COLLISION_DAMAGE'  в‹„ game.Cfg.COLLISION_DAMAGEв†ђcfg.COLLISION_DAMAGE    в‹„ :EndIf
              :If 0в‰ вЋ•NC'cfg.COLLISION_BOUNCE'  в‹„ game.Cfg.COLLISION_BOUNCEв†ђcfg.COLLISION_BOUNCE    в‹„ :EndIf
              :If 0в‰ вЋ•NC'cfg.MAX_TURNS'         в‹„ game.Cfg.MAX_TURNSв†ђcfg.MAX_TURNS                 в‹„ :EndIf
              вЌќ Resolve bots
              namesв†ђ{вЌµ.name}ВЁmanifest.bots
              botnsв†ђвЌ¬
              :For i :In вЌів‰ўnames
                  nsв†ђgame.BotLib.Resolve(iвЉѓnames)
                  botns,в†ђns
              :EndFor
              lastBotNamesв†ђnames
              lastMatchв†ђmanifest.seed game.Engine.Run botns
              req.SetStatus 201
              resultв†ђ(match: MatchSummary lastMatch в‹„ warnings: warnings)
          :Else
              RestoreCfg savedCfg
              вЋ•DMX.EM вЋ•SIGNAL вЋ•DMX.EN
          :EndTrap
      :Else
          req.Fail 500
          resultв†ђ(error: вЋ•DMX.Message)
      :EndTrap
    в€‡

    в€‡ {r}в†ђRunRemoteMatch args;botns;rec;matchRemotes;rem;finalAlive;finalHP;nBots;frames;alivePerFrame;deathFrames;scores;ranks;idx;dt
      :Access Private
      rв†ђвЌ¬
      вЋ•IOв†ђ0
      (botns rec matchRemotes)в†ђargs
      :Trap 0
          lastMatchв†ђgame.Engine.Run botns
          rec.matchв†ђlastMatch
      :Else
          вЌќ Match failed вЂ” ensure we don't hang
      :EndTrap
      rec.doneв†ђ1
      :If 0в‰ вЋ•NC'lastMatch.bots'
          finalAliveв†ђlastMatch.bots[;7]
          finalHPв†ђlastMatch.bots[;5]
          nBotsв†ђв‰ўfinalAlive
          вЌќ Compute death frame for each bot
          framesв†ђlastMatch.history
          alivePerFrameв†ђв†‘{вЌµ.bots[;7]}ВЁframes
          deathFramesв†ђ{вЌµвЌі0}ВЁв†“вЌ‰alivePerFrame
          вЌќ Rank: alive bots by HP (desc), dead bots by survival time (desc)
          scoresв†ђ(finalAliveГ—10000)+(finalAliveГ—finalHP)+((1-finalAlive)Г—deathFrames)
          ranksв†ђ1+вЌ‹вЌ‹-scores
          :For rem :In matchRemotes
              idxв†ђrem.botIndex
              rem.finalHPв†ђfinalHP[idx]
              rem.aliveв†ђfinalAlive[idx]
              rem.totalBotsв†ђnBots
              rem.rankв†ђidxвЉѓranks
              :If ~rem.alive
                  dtв†ђidxвЉѓdeathFrames
                  :If dt<в‰ўframes
                      rem.deathTurnв†ђ(dtвЉѓframes).turn
                  :Else
                      rem.deathTurnв†ђlastMatch.turn
                  :EndIf
              :EndIf
              rem.statusв†ђ'done'
          :EndFor
      :Else
          :For rem :In matchRemotes
              rem.statusв†ђ'done'
          :EndFor
      :EndIf
    в€‡

    в€‡ recв†ђNewMatchRecord names
      :Access Private
      recв†ђвЋ•NSвЌ¬
      rec.idв†ђnextMatchId
      rec.namesв†ђnames
      rec.matchв†ђвЌ¬
      rec.doneв†ђ0
      matches,в†ђrec
      nextMatchIdв†ђnextMatchId+1
    в€‡

    в€‡ resultв†ђListMatches req
      :Access Public
      вЋ•IOв†ђ0
      resultв†ђ(matches: {вЋ•IOв†ђ0 в‹„ nsв†ђвЋ•NSвЌ¬ в‹„ ns.idв†ђвЌµ.id в‹„ ns.namesв†ђвЌµ.names в‹„ ns.doneв†ђвЌµ.done в‹„ ns.turnsв†ђ{вЌ¬в‰ЎвЌµ:0 в‹„ вЌµ.turn}вЌµ.match в‹„ ns}ВЁmatches)
    в€‡

    в€‡ resultв†ђGetMatchHistory req;id;valid;vals;idx;rec;frames
      :Access Public
      вЋ•IOв†ђ0
      (valid vals)в†ђвЋ•VFI req.PathParams.id
      :If ~в€Ё/valid
          req.Fail 400
          resultв†ђ(detail: 'Invalid match ID')
          :Return
      :EndIf
      idв†ђвЉѓvalid/vals
      idxв†ђ{вЌµ.id}ВЁmatches
      :If ~idв€Љidx
          req.Fail 404
          resultв†ђ(detail: 'Match not found')
          :Return
      :EndIf
      recв†ђ(idxвЌіid)вЉѓmatches
      :If вЌ¬в‰Ўrec.match
          :If ~rec.done
              resultв†ђ(detail: 'Match not yet started' в‹„ id: id)
          :Else
              req.Fail 500
              resultв†ђ(detail: 'Match failed')
          :EndIf
          :Return
      :EndIf
      framesв†ђ{(turn: вЌµ.turn в‹„ bots: вЌµ.bots в‹„ bullets: вЌµ.bullets)}ВЁrec.match.history
      resultв†ђ(
        turns: rec.match.turn
        done: rec.match.done
        names: rec.match.names
        arena: game.Cfg.ARENA
        botRadius: game.Cfg.BOT_RADIUS
        visionRange: game.Cfg.VISION_RANGE
        visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
        botHP: game.Cfg.BOT_HP
        frames: frames
      )
    в€‡

    в€‡ remв†ђResolveSlot(slot token);valid;vals;idx
      :Access Private
      вЋ•IOв†ђ0
      (valid vals)в†ђвЋ•VFIвЌ•slot
      :If ~в€Ё/valid
          remв†ђвЌ¬
          :Return
      :EndIf
      slotв†ђвЉѓvalid/vals
      idxв†ђ{вЌµ.slot}ВЁremotes
      :If ~slotв€Љidx
          remв†ђвЌ¬
          :Return
      :EndIf
      remв†ђ(idxвЌіslot)вЉѓremotes
      :If tokenв‰ўrem.secret
          remв†ђвЌ¬
      :EndIf
    в€‡

    в€‡ resultв†ђListRemotes req
      :Access Public
      вЋ•IOв†ђ0
      resultв†ђ(remotes: {вЋ•IOв†ђ0 в‹„ nsв†ђвЋ•NSвЌ¬ в‹„ ns.slotв†ђвЌµ.slot в‹„ ns.statusв†ђвЌµ.status в‹„ ns.tickв†ђвЌµ.tick в‹„ ns}ВЁremotes)
    в€‡

    в€‡ resultв†ђGetRemoteState req;rem;input;vis
      :Access Public
      вЋ•IOв†ђ0
      remв†ђResolveSlot req.PathParams.slot req.PathParams.token
      :If вЌ¬в‰Ўrem
          req.Fail 404
          resultв†ђ(detail: 'Remote slot not found')
          :Return
      :EndIf
      :Select rem.status
      :Case 'idle'
          req.Fail 404
          resultв†ђ(detail: 'Remote not yet started')
      :Case 'done'
          resultв†ђвЋ•NSвЌ¬
          result.statusв†ђ'done'
          result.turnв†ђrem.tick
          result.hpв†ђrem.finalHP
          result.aliveв†ђrem.alive
          result.rankв†ђrem.rank
          result.totalBotsв†ђrem.totalBots
          :If ВЇ1в‰ўrem.deathTurn
              result.deathTurnв†ђrem.deathTurn
          :EndIf
      :Case 'processing'
          resultв†ђ(status: 'processing' в‹„ turn: rem.tick)
      :Case 'waiting'
          inputв†ђrem.pendingInput
          resultв†ђвЋ•NSвЌ¬
          result.statusв†ђ'active'
          result.turnв†ђinput.turn
          result.positionв†ђinput.loc
          result.directionв†ђinput.direction
          result.turretв†ђinput.turret
          result.hpв†ђinput.hp
          result.arenaв†ђinput.arena
          result.configв†ђinput.cfg
          visв†ђinput.visible
          :If 0<в‰ўvis
              result.visibleв†ђ{nsв†ђвЋ•NSвЌ¬ в‹„ ns.typeв†ђ(вЌµ[2])вЉѓ'rhobot' 'bullet' в‹„ ns.distanceв†ђвЌµ[0] в‹„ ns.offsetв†ђвЌµ[1] в‹„ ns}ВЁв†“vis
          :Else
              result.visibleв†ђвЌ¬
          :EndIf
      :EndSelect
    в€‡

    в€‡ resultв†ђPostRemoteAction req;body;act;rem
      :Access Public
      вЋ•IOв†ђ0
      remв†ђResolveSlot req.PathParams.slot req.PathParams.token
      :If вЌ¬в‰Ўrem
          req.Fail 404
          resultв†ђ(detail: 'Remote slot not found')
          :Return
      :EndIf
      :If 'waiting'в‰ўrem.status
          :If 'done'в‰Ўrem.status
              resultв†ђ(status: 'done' в‹„ turn: rem.tick)
          :Else
              req.Fail 409
              resultв†ђ(detail: 'Remote bot is not waiting for input')
          :EndIf
          :Return
      :EndIf
      bodyв†ђreq.Payload
      actв†ђвЋ•NSвЌ¬
      :If 0в‰ body.вЋ•NC'direction' в‹„ act.directionв†ђbody.direction в‹„ :EndIf
      :If 0в‰ body.вЋ•NC'turret' в‹„ act.turretв†ђbody.turret в‹„ :EndIf
      :If 0в‰ body.вЋ•NC'fire' в‹„ act.fireв†ђbody.fire в‹„ :EndIf
      :If 0в‰ body.вЋ•NC'speed' в‹„ act.speedв†ђbody.speed в‹„ :EndIf
      act.stateв†ђrem.pendingInput.state
      rem.pendingActionв†ђact
      вЋ•TPUT rem.token
      resultв†ђ(ok: 1 в‹„ turn: rem.tick)
    в€‡

:EndClass
