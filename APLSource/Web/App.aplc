    ‚àá result‚ÜêGetRecord req;id;valid;vals;idx;rec
      :Access Public
      ‚éïIO‚Üê0
      (valid vals)‚Üê‚éïVFI req.PathParams.id
      :If ~‚à®/valid
          req.Fail 400
          result‚Üê(detail: 'Invalid match ID')
          :Return
      :EndIf
      id‚Üê‚äÉvalid/vals
      idx‚Üê{‚çµ.id}¬®matches
      :If ~id‚àäidx
          req.Fail 404
          result‚Üê(detail: 'Match not found')
          :Return
      :EndIf
      rec‚Üê(idx‚ç≥id)‚äÉmatches
      :If ‚ç¨‚â°rec.match
          req.Fail 404
          result‚Üê(detail: 'Match not yet complete')
          :Return
      :EndIf
      result‚Üêgame.Record.Create rec.match rec.names
    ‚àá

    ‚àá result‚ÜêReplayRecord req;body;manifest;names;botns;i;ns;warnings;savedCfg;cfg;rec
      :Access Public
      ‚éïIO‚Üê0
      :Trap 0
          body‚Üêreq.Payload
          manifest‚Üêbody
          ‚çù Validate manifest
          warnings‚Üêgame.Record.Validate manifest
          ‚çù Save current config and apply manifest config
          savedCfg‚ÜêSaveCfg
          :Trap 0
              cfg‚Üêmanifest.config
              :If 0‚âÝ‚éïNC'cfg.ARENA'             ‚ãÑ game.Cfg.ARENA‚Üêcfg.ARENA                         ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.BOT_SPEED'         ‚ãÑ game.Cfg.BOT_SPEED‚Üêcfg.BOT_SPEED                 ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.BOT_HP'            ‚ãÑ game.Cfg.BOT_HP‚Üêcfg.BOT_HP                       ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.BOT_RADIUS'        ‚ãÑ game.Cfg.BOT_RADIUS‚Üêcfg.BOT_RADIUS               ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.BULLET_SPEED'      ‚ãÑ game.Cfg.BULLET_SPEED‚Üêcfg.BULLET_SPEED           ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.BULLET_DAMAGE'     ‚ãÑ game.Cfg.BULLET_DAMAGE‚Üêcfg.BULLET_DAMAGE         ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.VISION_RANGE'      ‚ãÑ game.Cfg.VISION_RANGE‚Üêcfg.VISION_RANGE           ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.VISION_HALF_ANGLE' ‚ãÑ game.Cfg.VISION_HALF_ANGLE‚Üêcfg.VISION_HALF_ANGLE ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.COOLDOWN'          ‚ãÑ game.Cfg.COOLDOWN‚Üêcfg.COOLDOWN                   ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.COLLISION_DAMAGE'  ‚ãÑ game.Cfg.COLLISION_DAMAGE‚Üêcfg.COLLISION_DAMAGE    ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.COLLISION_BOUNCE'  ‚ãÑ game.Cfg.COLLISION_BOUNCE‚Üêcfg.COLLISION_BOUNCE    ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.MAX_TURNS'         ‚ãÑ game.Cfg.MAX_TURNS‚Üêcfg.MAX_TURNS                 ‚ãÑ :EndIf
              ‚çù Resolve bots
              names‚Üê{‚çµ.name}¬®manifest.bots
              botns‚Üê‚ç¨
              :For i :In ‚ç≥‚â¢names
                  ns‚Üêgame.BotLib.Resolve(i‚äÉnames)
                  botns,‚Üêns
              :EndFor
              lastBotNames‚Üênames
              rec‚ÜêNewMatchRecord names
              lastMatch‚Üêmanifest.seed game.Engine.Run botns
              rec.match‚ÜêlastMatch
              rec.done‚Üê1
              req.SetStatus 201
              result‚Üê(match: MatchSummary lastMatch ‚ãÑ warnings: warnings ‚ãÑ id: rec.id)
          :Else
              RestoreCfg savedCfg
              ‚éïDMX.EM ‚éïSIGNAL ‚éïDMX.EN
          :EndTrap
      :Else
          req.Fail 500
          result‚Üê(error: ‚éïDMX.Message)
      :EndTrap
    ‚àá

    ‚àá {r}‚ÜêRunMatch args;botns;rec;matchRemotes;rem;finalAlive;finalHP;nBots;frames;alivePerFrame;deathFrames;scores;ranks;idx;dt;match;seed;i;hitLog;myHits;hitsOnMe;j;hitsOnJ;standings;ns
      :Access Private
      r‚Üê‚ç¨
      ‚éïIO‚Üê0
      (botns rec matchRemotes)‚Üêargs
      :Trap 0
          ‚çù Inline Engine.Run for live viewing (rec.match set before loop)
          seed‚Üê?2147483646
          game.Engine.‚éïRL‚Üêseed
          :For i :In ‚ç≥‚â¢botns
              (i‚äÉbotns).‚éïRL‚Üêseed
          :EndFor
          match‚Üêgame.Engine.Init botns
          match.seed‚Üêseed
          rec.match‚Üêmatch
          :While ~match.done
              match‚Üêgame.Engine.Tick match
          :EndWhile
          match.history,‚Üê‚äÇ(turn: match.turn ‚ãÑ bots: match.bots ‚ãÑ bullets: match.bullets ‚ãÑ thoughts: match.thoughts)
          lastMatch‚Üêmatch
      :Else
          ‚çù Match failed ‚Äî ensure we don't hang
      :EndTrap
      rec.done‚Üê1
      :If 0‚âÝ‚éïNC'lastMatch.bots'
          finalAlive‚ÜêlastMatch.bots[;7]
          finalHP‚ÜêlastMatch.bots[;5]
          nBots‚Üê‚â¢finalAlive
          ‚çù Compute death frame for each bot
          frames‚ÜêlastMatch.history
          alivePerFrame‚Üê‚Üë{‚çµ.bots[;7]}¬®frames
          deathFrames‚Üê{‚çµ‚ç≥0}¬®‚Üì‚çâalivePerFrame
          ‚çù Rank: alive bots by HP (desc), dead bots by survival time (desc)
          scores‚Üê(finalAlive√ó10000)+(finalAlive√ófinalHP)+((1-finalAlive)√ódeathFrames)
          ranks‚Üê1+‚çã‚çã-scores
          ‚çù Build standings for done response
          standings‚Üê{‚éïIO‚Üê0 ‚ãÑ ns‚Üê‚éïNS‚ç¨ ‚ãÑ ns.name‚Üê‚ç∫ ‚ãÑ ns.hp‚Üê‚çµ ‚ãÑ ns.rank‚Üê(‚ç≥‚â¢ranks)‚äÉranks ‚ãÑ ns}¬®‚ç®/‚Üì(‚ÜëlastMatch.names)(finalHP)
          ‚çù Actually build properly ‚Äî need rank per bot
          standings‚Üê‚ç¨
          :For idx :In ‚ç≥nBots
              ns‚Üê‚éïNS‚ç¨
              ns.name‚Üê‚çïidx‚äÉlastMatch.names
              ns.hp‚ÜêfinalHP[idx]
              ns.alive‚ÜêfinalAlive[idx]
              ns.rank‚Üêidx‚äÉranks
              standings,‚Üêns
          :EndFor
          ‚çù Compute per-bot hit/kill stats from hitLog
          hitLog‚ÜêlastMatch.hitLog
          :For rem :In matchRemotes
              idx‚Üêrem.botIndex
              rem.finalHP‚ÜêfinalHP[idx]
              rem.alive‚ÜêfinalAlive[idx]
              rem.totalBots‚ÜênBots
              rem.rank‚Üêidx‚äÉranks
              rem.standings‚Üêstandings
              ‚çù Combat stats
              :If 0<‚â¢hitLog
                  myHits‚Üê(idx={‚äÉ‚çµ}¬®hitLog)/hitLog
                  rem.shotsHit‚Üê‚â¢myHits
                  ‚çù Kills: dead bots where my bullet was the last to hit them
                  rem.kills‚Üê0
                  :For j :In ‚ç∏~finalAlive
                      hitsOnJ‚Üê(j={1‚äÉ‚çµ}¬®hitLog)/hitLog
                      :If 0<‚â¢hitsOnJ
                          :If idx=‚äÉ‚äÉ‚åΩhitsOnJ
                              rem.kills+‚Üê1
                          :EndIf
                      :EndIf
                  :EndFor
                  hitsOnMe‚Üê(idx={1‚äÉ‚çµ}¬®hitLog)/hitLog
                  rem.damageTaken‚Üê+/{2‚äÉ‚çµ}¬®hitsOnMe
              :Else
                  rem.shotsHit‚Üê0
                  rem.kills‚Üê0
                  rem.damageTaken‚Üê0
              :EndIf
              :If ~rem.alive
                  dt‚Üêidx‚äÉdeathFrames
                  :If dt<‚â¢frames
                      rem.deathTurn‚Üê(dt‚äÉframes).turn
                  :Else
                      rem.deathTurn‚ÜêlastMatch.turn
                  :EndIf
              :EndIf
              rem.status‚Üê'done'
          :EndFor
      :Else
          :For rem :In matchRemotes
              rem.status‚Üê'done'
          :EndFor
      :EndIf
      SaveMatch rec
    ‚àá

    ‚àá result‚ÜêEndMatch req;id;valid;vals;idx;rec
      :Access Public
      ‚éïIO‚Üê0
      (valid vals)‚Üê‚éïVFI req.PathParams.id
      :If ~‚à®/valid
          req.Fail 400
          result‚Üê(detail: 'Invalid match ID')
          :Return
      :EndIf
      id‚Üê‚äÉvalid/vals
      idx‚Üê{‚çµ.id}¬®matches
      :If ~id‚àäidx
          req.Fail 404
          result‚Üê(detail: 'Match not found')
          :Return
      :EndIf
      rec‚Üê(idx‚ç≥id)‚äÉmatches
      :If ‚ç¨‚â°rec.match
          req.Fail 404
          result‚Üê(detail: 'Match not started')
          :Return
      :EndIf
      :If rec.done
          result‚Üê(detail: 'Match already finished')
          :Return
      :EndIf
      rec.match.done‚Üê1
      result‚Üê(detail: 'Match ending ‚Äî will complete on next tick')
    ‚àá

    ‚àá rec‚ÜêNewMatchRecord names
      :Access Private
      rec‚Üê‚éïNS‚ç¨
      rec.id‚ÜênextMatchId
      rec.names‚Üênames
      rec.match‚Üê‚ç¨
      rec.done‚Üê0
      matches,‚Üêrec
      nextMatchId‚ÜênextMatchId+1
    ‚àá

    ‚àá {r}‚ÜêSaveMatch rec;manifest;path;json
      :Access Private
      ‚éïIO‚Üê0
      r‚Üê‚ç¨
      :Trap 0
          manifest‚Üêgame.Record.Create rec.match rec.names
          manifest.id‚Üêrec.id
          json‚Üê‚éïJSON manifest
          path‚Üê'matches/match-',(‚çïrec.id),'.json'
          (‚äÇjson)‚éïNPUT path 1
      :Else
          (‚äÇ'SaveMatch error: ',‚éïDMX.Message,' at ',‚äÉ‚éïDMX.DM)‚éïNPUT 'matches/error.txt' 1
      :EndTrap
    ‚àá

    ‚àá {r}‚ÜêLoadSavedMatches;files;f;json;data;rec;match;frame;i
      :Access Private
      ‚éïIO‚Üê0
      r‚Üê‚ç¨
      :Trap 0
          files‚Üê‚äÉ0 ‚éïNINFO‚çÝ1‚ä¢'matches/match-*.json'
      :Else
          :Return
      :EndTrap
      :If 0=‚â¢files ‚ãÑ :Return ‚ãÑ :EndIf
      :For f :In files
          :Trap 0
              json‚Üê‚àä‚äÉ‚éïNGET f 1
              data‚Üê‚éïJSON json
              ‚çù Reconstruct match namespace from saved data
              match‚Üê‚éïNS‚ç¨
              match.turn‚Üêdata.turns
              match.done‚Üêdata.done
              match.names‚Üê{‚çµ.name}¬®data.bots
              match.seed‚Üêdata.seed
              ‚çù Final bot state from last frame (or finalBots if present)
              :If 0‚âÝ‚éïNC'data.finalBots'
                  match.bots‚Üê‚Üëdata.finalBots
              :ElseIf 0<‚â¢data.frames
                  match.bots‚Üê‚Üë(‚äÉ‚åΩdata.frames).bots
              :Else
                  match.bots‚Üê0 8‚ç¥0
              :EndIf
              match.bullets‚Üê0 5‚ç¥0
              match.hitLog‚Üê‚ç¨
              match.thoughts‚Üê(‚â¢data.bots)‚ç¥‚äÇ''
              match.thoughtAges‚Üê(‚â¢data.bots)‚ç¥0
              match.tokenBase‚Üê0
              ‚çù Reconstruct history frames
              match.history‚Üê‚ç¨
              :If 0‚âÝ‚éïNC'data.frames'
                  :For i :In ‚ç≥‚â¢data.frames
                      frame‚Üê‚éïNS‚ç¨
                      frame.turn‚Üê(i‚äÉdata.frames).turn
                      frame.bots‚Üê‚Üë(i‚äÉdata.frames).bots
                      frame.bullets‚Üê{0=‚â¢‚çµ:0 5‚ç¥0 ‚ãÑ ‚Üë‚çµ}(i‚äÉdata.frames).bullets
                      frame.thoughts‚Üê{6::‚ç¨ ‚ãÑ ‚çµ.thoughts}i‚äÉdata.frames
                      match.history,‚Üê‚äÇframe
                  :EndFor
              :EndIf
              ‚çù Create match record
              rec‚Üê‚éïNS‚ç¨
              rec.id‚Üêdata.id
              rec.names‚Üê{‚çµ.name}¬®data.bots
              rec.match‚Üêmatch
              rec.done‚Üê1
              matches,‚Üêrec
              :If rec.id‚â•nextMatchId
                  nextMatchId‚Üêrec.id+1
              :EndIf
          :Else
              ‚çù Skip corrupt files
          :EndTrap
      :EndFor
    ‚àá

    ‚àá result‚ÜêListMatches req
      :Access Public
      ‚éïIO‚Üê0
      result‚Üê(matches: {‚éïIO‚Üê0 ‚ãÑ ns‚Üê‚éïNS‚ç¨ ‚ãÑ ns.id‚Üê‚çµ.id ‚ãÑ ns.names‚Üê‚çµ.names ‚ãÑ ns.done‚Üê‚çµ.done ‚ãÑ ns.turns‚Üê{‚ç¨‚â°‚çµ:0 ‚ãÑ ‚çµ.turn}‚çµ.match ‚ãÑ ns}¬®matches)
    ‚àá

    ‚àá result‚ÜêGetMatchHistory req;id;valid;vals;idx;rec;frames
      :Access Public
      ‚éïIO‚Üê0
      (valid vals)‚Üê‚éïVFI req.PathParams.id
      :If ~‚à®/valid
          req.Fail 400
          result‚Üê(detail: 'Invalid match ID')
          :Return
      :EndIf
      id‚Üê‚äÉvalid/vals
      idx‚Üê{‚çµ.id}¬®matches
      :If ~id‚àäidx
          req.Fail 404
          result‚Üê(detail: 'Match not found')
          :Return
      :EndIf
      rec‚Üê(idx‚ç≥id)‚äÉmatches
      :If ‚ç¨‚â°rec.match
          :If ~rec.done
              result‚Üê(detail: 'Match not yet started' ‚ãÑ id: id)
          :Else
              req.Fail 500
              result‚Üê(detail: 'Match failed')
          :EndIf
          :Return
      :EndIf
      frames‚Üê{(turn: ‚çµ.turn ‚ãÑ bots: ‚çµ.bots ‚ãÑ bullets: ‚çµ.bullets ‚ãÑ thoughts: {6::‚ç¨ ‚ãÑ ‚çµ.thoughts}‚çµ)}¬®rec.match.history
      result‚Üê(
        turns: rec.match.turn
        done: rec.match.done
        names: rec.match.names
        arena: game.Cfg.ARENA
        botRadius: game.Cfg.BOT_RADIUS
        visionRange: game.Cfg.VISION_RANGE
        visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
        botHP: game.Cfg.BOT_HP
        frames: frames
      )
    ‚àá

    ‚àá result‚ÜêGetSituation req;id;valid;vals;idx;rec;m;bots;i;ns;hitLog;hitsBy;hitsOn;lastHitter
      :Access Public
      ‚éïIO‚Üê0
      (valid vals)‚Üê‚éïVFI req.PathParams.id
      :If ~‚à®/valid
          req.Fail 400
          result‚Üê(detail: 'Invalid match ID')
          :Return
      :EndIf
      id‚Üê‚äÉvalid/vals
      idx‚Üê{‚çµ.id}¬®matches
      :If ~id‚àäidx
          req.Fail 404
          result‚Üê(detail: 'Match not found')
          :Return
      :EndIf
      rec‚Üê(idx‚ç≥id)‚äÉmatches
      :If ‚ç¨‚â°rec.match
          req.Fail 404
          result‚Üê(detail: 'Match not yet started')
          :Return
      :EndIf
      m‚Üêrec.match
      bots‚Üêm.bots
      hitLog‚Üêm.hitLog
      result‚Üê‚éïNS‚ç¨
      result.turn‚Üêm.turn
      result.done‚Üêm.done
      result.bots‚Üê‚ç¨
      :For i :In ‚ç≥‚â¢bots
          ns‚Üê‚éïNS‚ç¨
          ns.name‚Üê‚çïi‚äÉm.names
          ns.hp‚Üêbots[i;5]
          ns.alive‚Üêbots[i;7]
          ns.x‚Üêbots[i;1]
          ns.y‚Üêbots[i;2]
          ns.direction‚Üêbots[i;3]
          ns.turret‚Üêbots[i;4]
          ‚çù Combat stats from hitLog
          :If 0<‚â¢hitLog
              hitsBy‚Üê(i={‚äÉ‚çµ}¬®hitLog)/hitLog
              hitsOn‚Üê(i={1‚äÉ‚çµ}¬®hitLog)/hitLog
              ns.shotsHit‚Üê‚â¢hitsBy
              ns.damageTaken‚Üê+/{2‚äÉ‚çµ}¬®hitsOn
              ns.damageDealt‚Üê+/{2‚äÉ‚çµ}¬®hitsBy
              ‚çù Kills: dead bots where I was last to hit
              ns.kills‚Üê0
              :For j :In ‚ç∏~bots[;7]
                  lastHitter‚Üê(j={1‚äÉ‚çµ}¬®hitLog)/hitLog
                  :If 0<‚â¢lastHitter
                      :If i=‚äÉ‚äÉ‚åΩlastHitter
                          ns.kills+‚Üê1
                      :EndIf
                  :EndIf
              :EndFor
          :Else
              ns.shotsHit‚Üê0
              ns.damageTaken‚Üê0
              ns.damageDealt‚Üê0
              ns.kills‚Üê0
          :EndIf
          result.bots,‚Üêns
      :EndFor
      ‚çù Bullets: position, heading, owner
      :If 0<‚â¢m.bullets
          result.bullets‚Üê{‚éïIO‚Üê0 ‚ãÑ ns‚Üê‚éïNS‚ç¨ ‚ãÑ ns.x‚Üê‚çµ[0] ‚ãÑ ns.y‚Üê‚çµ[1] ‚ãÑ ns.heading‚Üê(180√∑‚óã1)√ó12‚óã(0J1√ó‚çµ[2])+‚çµ[3] ‚ãÑ ns.owner‚Üê‚çµ[4] ‚ãÑ ns}¬®‚Üìm.bullets
      :Else
          result.bullets‚Üê‚ç¨
      :EndIf
    ‚àá

    ‚àá rem‚ÜêResolveSlot(slot token);valid;vals;idx
      :Access Private
      ‚éïIO‚Üê0
      (valid vals)‚Üê‚éïVFI‚çïslot
      :If ~‚à®/valid
          rem‚Üê‚ç¨
          :Return
      :EndIf
      slot‚Üê‚äÉvalid/vals
      idx‚Üê{‚çµ.slot}¬®remotes
      :If ~slot‚àäidx
          rem‚Üê‚ç¨
          :Return
      :EndIf
      rem‚Üê(idx‚ç≥slot)‚äÉremotes
      :If token‚â¢rem.secret
          rem‚Üê‚ç¨
      :EndIf
    ‚àá

    ‚àá result‚ÜêListRemotes req
      :Access Public
      ‚éïIO‚Üê0
      result‚Üê(remotes: {‚éïIO‚Üê0 ‚ãÑ ns‚Üê‚éïNS‚ç¨ ‚ãÑ ns.slot‚Üê‚çµ.slot ‚ãÑ ns.status‚Üê‚çµ.status ‚ãÑ ns.tick‚Üê‚çµ.tick ‚ãÑ ns}¬®remotes)
    ‚àá

    ‚àá result‚ÜêGetRemoteState req;rem;input;vis
      :Access Public
      ‚éïIO‚Üê0
      rem‚ÜêResolveSlot req.PathParams.slot req.PathParams.token
      :If ‚ç¨‚â°rem
          req.Fail 404
          result‚Üê(detail: 'Remote slot not found')
          :Return
      :EndIf
      :Select rem.status
      :Case 'idle'
          req.Fail 404
          result‚Üê(detail: 'Remote not yet started')
      :Case 'done'
          result‚Üê‚éïNS‚ç¨
          result.status‚Üê'done'
          result.turn‚Üêrem.tick
          result.hp‚Üêrem.finalHP
          result.alive‚Üêrem.alive
          result.rank‚Üêrem.rank
          result.totalBots‚Üêrem.totalBots
          :If ¬Ø1‚â¢rem.deathTurn
              result.deathTurn‚Üêrem.deathTurn
          :EndIf
          :If 0‚âÝrem.‚éïNC'standings'
              result.standings‚Üêrem.standings
          :EndIf
          :If 0‚âÝrem.‚éïNC'shotsHit'
              result.shotsHit‚Üêrem.shotsHit
              result.kills‚Üêrem.kills
              result.damageTaken‚Üêrem.damageTaken
          :EndIf
      :Case 'processing'
          result‚Üê(status: 'processing' ‚ãÑ turn: rem.tick)
      :Case 'waiting'
          input‚Üêrem.pendingInput
          result‚Üê‚éïNS‚ç¨
          result.status‚Üê'active'
          result.turn‚Üêinput.turn
          result.position‚Üêinput.loc
          result.direction‚Üêinput.direction
          result.turret‚Üêinput.turret
          result.hp‚Üêinput.hp
          result.arena‚Üêinput.arena
          result.config‚Üêinput.cfg
          vis‚Üêinput.visible
          :If 0<‚â¢vis
              result.visible‚Üê{ns‚Üê‚éïNS‚ç¨ ‚ãÑ ns.type‚Üê(‚çµ[2])‚äÉ'rhobot' 'bullet' ‚ãÑ ns.distance‚Üê‚çµ[0] ‚ãÑ ns.offset‚Üê‚çµ[1] ‚ãÑ ns}¬®‚Üìvis
          :Else
              result.visible‚Üê‚ç¨
          :EndIf
          result.state‚Üêinput.state
      :EndSelect
    ‚àá

    ‚àá result‚ÜêPostRemoteAction req;body;act;rem
      :Access Public
      ‚éïIO‚Üê0
      rem‚ÜêResolveSlot req.PathParams.slot req.PathParams.token
      :If ‚ç¨‚â°rem
          req.Fail 404
          result‚Üê(detail: 'Remote slot not found')
          :Return
      :EndIf
      :If 'waiting'‚â¢rem.status
          :If 'done'‚â°rem.status
              result‚Üê(status: 'done' ‚ãÑ turn: rem.tick)
          :Else
              req.Fail 409
              result‚Üê(detail: 'Remote bot is not waiting for input')
          :EndIf
          :Return
      :EndIf
      body‚Üêreq.Payload
      act‚Üê‚éïNS‚ç¨
      :If 0‚âÝbody.‚éïNC'direction' ‚ãÑ act.direction‚Üêbody.direction ‚ãÑ :EndIf
      :If 0‚âÝbody.‚éïNC'turret' ‚ãÑ act.turret‚Üêbody.turret ‚ãÑ :EndIf
      :If 0‚âÝbody.‚éïNC'fire' ‚ãÑ act.fire‚Üêbody.fire ‚ãÑ :EndIf
      :If 0‚âÝbody.‚éïNC'speed' ‚ãÑ act.speed‚Üêbody.speed ‚ãÑ :EndIf
      :If 0‚âÝbody.‚éïNC'thought' ‚ãÑ act.thought‚Üêbody.thought ‚ãÑ :EndIf
      :If 0‚âÝbody.‚éïNC'state'
          act.state‚Üêbody.state
      :Else
          act.state‚Üêrem.pendingInput.state
      :EndIf
      rem.pendingAction‚Üêact
      ‚éïTPUT rem.token
      result‚Üê(ok: 1 ‚ãÑ turn: rem.tick)
    ‚àá

:EndClass
