    ‚ąá result‚ÜźGetRecord req;id;valid;vals;idx;rec
      :Access Public
      ‚éēIO‚Üź0
      (valid vals)‚Üź‚éēVFI req.PathParams.id
      :If ~‚ą®/valid
          req.Fail 400
          result‚Üź(detail: 'Invalid match ID')
          :Return
      :EndIf
      id‚Üź‚äÉvalid/vals
      idx‚Üź{‚ćĶ.id}¬®matches
      :If ~id‚ąäidx
          req.Fail 404
          result‚Üź(detail: 'Match not found')
          :Return
      :EndIf
      rec‚Üź(idx‚ć≥id)‚äÉmatches
      :If ‚ć¨‚Č°rec.match
          req.Fail 404
          result‚Üź(detail: 'Match not yet complete')
          :Return
      :EndIf
      result‚Üźgame.Record.Create rec.match rec.names
    ‚ąá

    ‚ąá result‚ÜźReplayRecord req;body;manifest;names;botns;i;ns;warnings;savedCfg;cfg;rec
      :Access Public
      ‚éēIO‚Üź0
      :Trap 0
          body‚Üźreq.Payload
          manifest‚Üźbody
          ‚ćĚ Validate manifest
          warnings‚Üźgame.Record.Validate manifest
          ‚ćĚ Save current config and apply manifest config
          savedCfg‚ÜźSaveCfg
          :Trap 0
              cfg‚Üźmanifest.config
              :If 0‚Č†‚éēNC'cfg.ARENA'             ‚čĄ game.Cfg.ARENA‚Üźcfg.ARENA                         ‚čĄ :EndIf
              :If 0‚Č†‚éēNC'cfg.BOT_SPEED'         ‚čĄ game.Cfg.BOT_SPEED‚Üźcfg.BOT_SPEED                 ‚čĄ :EndIf
              :If 0‚Č†‚éēNC'cfg.BOT_HP'            ‚čĄ game.Cfg.BOT_HP‚Üźcfg.BOT_HP                       ‚čĄ :EndIf
              :If 0‚Č†‚éēNC'cfg.BOT_RADIUS'        ‚čĄ game.Cfg.BOT_RADIUS‚Üźcfg.BOT_RADIUS               ‚čĄ :EndIf
              :If 0‚Č†‚éēNC'cfg.BULLET_SPEED'      ‚čĄ game.Cfg.BULLET_SPEED‚Üźcfg.BULLET_SPEED           ‚čĄ :EndIf
              :If 0‚Č†‚éēNC'cfg.BULLET_DAMAGE'     ‚čĄ game.Cfg.BULLET_DAMAGE‚Üźcfg.BULLET_DAMAGE         ‚čĄ :EndIf
              :If 0‚Č†‚éēNC'cfg.VISION_RANGE'      ‚čĄ game.Cfg.VISION_RANGE‚Üźcfg.VISION_RANGE           ‚čĄ :EndIf
              :If 0‚Č†‚éēNC'cfg.VISION_HALF_ANGLE' ‚čĄ game.Cfg.VISION_HALF_ANGLE‚Üźcfg.VISION_HALF_ANGLE ‚čĄ :EndIf
              :If 0‚Č†‚éēNC'cfg.COOLDOWN'          ‚čĄ game.Cfg.COOLDOWN‚Üźcfg.COOLDOWN                   ‚čĄ :EndIf
              :If 0‚Č†‚éēNC'cfg.COLLISION_DAMAGE'  ‚čĄ game.Cfg.COLLISION_DAMAGE‚Üźcfg.COLLISION_DAMAGE    ‚čĄ :EndIf
              :If 0‚Č†‚éēNC'cfg.COLLISION_BOUNCE'  ‚čĄ game.Cfg.COLLISION_BOUNCE‚Üźcfg.COLLISION_BOUNCE    ‚čĄ :EndIf
              :If 0‚Č†‚éēNC'cfg.MAX_TURNS'         ‚čĄ game.Cfg.MAX_TURNS‚Üźcfg.MAX_TURNS                 ‚čĄ :EndIf
              ‚ćĚ Resolve bots
              names‚Üź{‚ćĶ.name}¬®manifest.bots
              botns‚Üź‚ć¨
              :For i :In ‚ć≥‚ČĘnames
                  ns‚Üźgame.BotLib.Resolve(i‚äÉnames)
                  botns,‚Üźns
              :EndFor
              lastBotNames‚Üźnames
              rec‚ÜźNewMatchRecord names
              lastMatch‚Üźmanifest.seed game.Engine.Run botns
              rec.match‚ÜźlastMatch
              rec.done‚Üź1
              req.SetStatus 201
              result‚Üź(match: MatchSummary lastMatch ‚čĄ warnings: warnings ‚čĄ id: rec.id)
          :Else
              RestoreCfg savedCfg
              ‚éēDMX.EM ‚éēSIGNAL ‚éēDMX.EN
          :EndTrap
      :Else
          req.Fail 500
          result‚Üź(error: ‚éēDMX.Message)
      :EndTrap
    ‚ąá

    ‚ąá {r}‚ÜźRunMatch args;botns;rec;matchRemotes;rem;finalAlive;finalHP;nBots;frames;alivePerFrame;deathFrames;scores;ranks;idx;dt;match;seed;i;hitLog;myHits;hitsOnMe;j;hitsOnJ;standings;ns
      :Access Private
      r‚Üź‚ć¨
      ‚éēIO‚Üź0
      (botns rec matchRemotes)‚Üźargs
      :Trap 0
          ‚ćĚ Inline Engine.Run so rec.match is live during execution
          seed‚Üź?2147483646
          ‚éēRL‚Üźseed
          :For i :In ‚ć≥‚ČĘbotns
              (i‚äÉbotns).‚éēRL‚Üźseed
          :EndFor
          match‚Üźgame.Engine.Init botns
          match.seed‚Üźseed
          rec.match‚Üźmatch
          :While ~match.done
              match‚Üźgame.Engine.Tick match
          :EndWhile
          match.history,‚Üź‚äā(turn: match.turn ‚čĄ bots: match.bots ‚čĄ bullets: match.bullets ‚čĄ thoughts: match.thoughts)
          lastMatch‚Üźmatch
      :Else
          ‚ćĚ Match failed ‚ÄĒ ensure we don't hang
      :EndTrap
      rec.done‚Üź1
      :If 0‚Č†‚éēNC'lastMatch.bots'
          finalAlive‚ÜźlastMatch.bots[;7]
          finalHP‚ÜźlastMatch.bots[;5]
          nBots‚Üź‚ČĘfinalAlive
          ‚ćĚ Compute death frame for each bot
          frames‚ÜźlastMatch.history
          alivePerFrame‚Üź‚ÜĎ{‚ćĶ.bots[;7]}¬®frames
          deathFrames‚Üź{‚ćĶ‚ć≥0}¬®‚Üď‚ćČalivePerFrame
          ‚ćĚ Rank: alive bots by HP (desc), dead bots by survival time (desc)
          scores‚Üź(finalAlive√ó10000)+(finalAlive√ófinalHP)+((1-finalAlive)√ódeathFrames)
          ranks‚Üź1+‚ćč‚ćč-scores
          ‚ćĚ Build standings for done response
          standings‚Üź{‚éēIO‚Üź0 ‚čĄ ns‚Üź‚éēNS‚ć¨ ‚čĄ ns.name‚Üź‚ćļ ‚čĄ ns.hp‚Üź‚ćĶ ‚čĄ ns.rank‚Üź(‚ć≥‚ČĘranks)‚äÉranks ‚čĄ ns}¬®‚ć®/‚Üď(‚ÜĎlastMatch.names)(finalHP)
          ‚ćĚ Actually build properly ‚ÄĒ need rank per bot
          standings‚Üź‚ć¨
          :For idx :In ‚ć≥nBots
              ns‚Üź‚éēNS‚ć¨
              ns.name‚Üź‚ćēidx‚äÉlastMatch.names
              ns.hp‚ÜźfinalHP[idx]
              ns.alive‚ÜźfinalAlive[idx]
              ns.rank‚Üźidx‚äÉranks
              standings,‚Üźns
          :EndFor
          ‚ćĚ Compute per-bot hit/kill stats from hitLog
          hitLog‚ÜźlastMatch.hitLog
          :For rem :In matchRemotes
              idx‚Üźrem.botIndex
              rem.finalHP‚ÜźfinalHP[idx]
              rem.alive‚ÜźfinalAlive[idx]
              rem.totalBots‚ÜźnBots
              rem.rank‚Üźidx‚äÉranks
              rem.standings‚Üźstandings
              ‚ćĚ Combat stats
              :If 0<‚ČĘhitLog
                  myHits‚Üź(idx={‚äÉ‚ćĶ}¬®hitLog)/hitLog
                  rem.shotsHit‚Üź‚ČĘmyHits
                  ‚ćĚ Kills: dead bots where my bullet was the last to hit them
                  rem.kills‚Üź0
                  :For j :In ‚ćł~finalAlive
                      hitsOnJ‚Üź(j={1‚äÉ‚ćĶ}¬®hitLog)/hitLog
                      :If 0<‚ČĘhitsOnJ
                          :If idx=‚äÉ‚äÉ‚ĆĹhitsOnJ
                              rem.kills+‚Üź1
                          :EndIf
                      :EndIf
                  :EndFor
                  hitsOnMe‚Üź(idx={1‚äÉ‚ćĶ}¬®hitLog)/hitLog
                  rem.damageTaken‚Üź+/{2‚äÉ‚ćĶ}¬®hitsOnMe
              :Else
                  rem.shotsHit‚Üź0
                  rem.kills‚Üź0
                  rem.damageTaken‚Üź0
              :EndIf
              :If ~rem.alive
                  dt‚Üźidx‚äÉdeathFrames
                  :If dt<‚ČĘframes
                      rem.deathTurn‚Üź(dt‚äÉframes).turn
                  :Else
                      rem.deathTurn‚ÜźlastMatch.turn
                  :EndIf
              :EndIf
              rem.status‚Üź'done'
          :EndFor
      :Else
          :For rem :In matchRemotes
              rem.status‚Üź'done'
          :EndFor
      :EndIf
      SaveMatch rec
    ‚ąá

    ‚ąá result‚ÜźEndMatch req;id;valid;vals;idx;rec
      :Access Public
      ‚éēIO‚Üź0
      (valid vals)‚Üź‚éēVFI req.PathParams.id
      :If ~‚ą®/valid
          req.Fail 400
          result‚Üź(detail: 'Invalid match ID')
          :Return
      :EndIf
      id‚Üź‚äÉvalid/vals
      idx‚Üź{‚ćĶ.id}¬®matches
      :If ~id‚ąäidx
          req.Fail 404
          result‚Üź(detail: 'Match not found')
          :Return
      :EndIf
      rec‚Üź(idx‚ć≥id)‚äÉmatches
      :If ‚ć¨‚Č°rec.match
          req.Fail 404
          result‚Üź(detail: 'Match not started')
          :Return
      :EndIf
      :If rec.done
          result‚Üź(detail: 'Match already finished')
          :Return
      :EndIf
      rec.match.done‚Üź1
      result‚Üź(detail: 'Match ending ‚ÄĒ will complete on next tick')
    ‚ąá

    ‚ąá rec‚ÜźNewMatchRecord names
      :Access Private
      rec‚Üź‚éēNS‚ć¨
      rec.id‚ÜźnextMatchId
      rec.names‚Üźnames
      rec.match‚Üź‚ć¨
      rec.done‚Üź0
      matches,‚Üźrec
      nextMatchId‚ÜźnextMatchId+1
    ‚ąá

    ‚ąá {r}‚ÜźSaveMatch rec;manifest;path;json
      :Access Private
      ‚éēIO‚Üź0
      r‚Üź‚ć¨
      :Trap 0
          manifest‚Üźgame.Record.Create rec.match rec.names
          manifest.id‚Üźrec.id
          json‚Üź‚éēJSON manifest
          path‚Üź'matches/match-',(‚ćērec.id),'.json'
          (‚äājson)‚éēNPUT path 1
      :Else
          (‚äā'SaveMatch error: ',‚éēDMX.Message,' at ',‚äÉ‚éēDMX.DM)‚éēNPUT 'matches/error.txt' 1
      :EndTrap
