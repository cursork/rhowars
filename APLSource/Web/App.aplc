:Class App
вНЭ rhowars web API вАФ Stark-based REST server
вНЭ
вНЭ   appвЖРвОХNEW rw.Web.App (StarkClass gameNS)
вНЭ   app.Start 8080

    :Field Private router
    :Field Private lastMatch
    :Field Private lastBotNames
    :Field Private game
    :Field Private defaultCfg
    :Field Private matches
    :Field Private nextMatchId
    :Field Private remotes
    :Field Private nextSlot

    вИЗ Make args;StarkClass
      :Access Public
      :Implements Constructor
      (StarkClass game)вЖРargs
      lastMatchвЖРвНђ
      lastBotNamesвЖРвНђ
      matchesвЖРвНђ
      nextMatchIdвЖР1
      remotesвЖРвНђ
      nextSlotвЖР0
      routerвЖРвОХNEW StarkClass
      router.HandlersвЖРвОХTHIS
      router.InfoвЖР(title: 'rhowars' вЛД version: '0.1.0')
      defaultCfgвЖРSaveCfg
      game.BotLib.LoadAll
      '/api/match/list' router.Get 'ListMatches'
      '/api/match/{id}/history' router.Get 'GetMatchHistory'
      '/api/match/{id}/record' router.Get 'GetRecord'
      '/api/match/replay' router.Post 'ReplayRecord'
      '/api/match/history' router.Get 'GetHistory'
      '/api/match' router.Post 'StartMatch'
      '/api/match' router.Get 'GetMatch'
      '/api/bots' router.Get 'ListBots'
      '/api/bots' router.Post 'UploadBot'
      '/api/bots/{author}/{name}' router.Delete 'DeleteBot'
      '/api/config' router.Get 'GetConfig'
      '/api/config/reset' router.Post 'ResetConfig'
      '/api/match/{id}/end' router.Post 'EndMatch'
      '/api/match/{id}/situation' router.Get 'GetSituation'
      '/api/remote/list' router.Get 'ListRemotes'
      '/api/remote/{slot}/{token}/state' router.Get 'GetRemoteState'
      '/api/remote/{slot}/{token}/action' router.Post 'PostRemoteAction'
    вИЗ

    вИЗ Start port
      :Access Public
      router.Start port
    вИЗ

    вИЗ Stop
      :Access Public
      router.Stop
    вИЗ

    вИЗ resultвЖРStartMatch req;body;names;botns;i;ns;rec;matchRemotes
      :Access Public
      вОХIOвЖР0
      :Trap 0
          bodyвЖРreq.Payload
          namesвЖРbody.bots
          вНЭ Apply ephemeral config if provided (persists until server restart)
          :If 0вЙ†вОХNC'body.config'
              ApplyCfg body.config
          :EndIf
          botnsвЖРвНђ
          matchRemotesвЖРвНђ
          :For i :In вН≥вЙҐnames
              :If 'Remote'вЙ°7вЖСiвКГnames
                  nsвЖРgame.Rhobots.Remote.Create nextSlot
                  ns.botIndexвЖРi
                  вНЭ Support Remote:Name format for display
                  :If ':'вИКiвКГnames
                      ns.вОХDF(1+(':'вН≥вН®iвКГnames))вЖУiвКГnames
                  :EndIf
                  remotes,вЖРns
                  matchRemotes,вЖРns
                  nextSlotвЖРnextSlot+1
              :Else
                  nsвЖРgame.BotLib.Resolve(iвКГnames)
              :EndIf
              botns,вЖРns
          :EndFor
          lastBotNamesвЖРnames
          recвЖРNewMatchRecord names
          RunMatch&(botns rec matchRemotes)
          req.SetStatus 202
          resultвЖРвОХNSвНђ
          result.idвЖРrec.id
          result.statusвЖР'running'
          :If 0<вЙҐmatchRemotes
              result.remotesвЖР{вОХIOвЖР0 вЛД nsвЖРвОХNSвНђ вЛД ns.slotвЖРвНµ.slot вЛД ns.tokenвЖРвНµ.secret вЛД ns}¬®matchRemotes
          :EndIf
      :Else
          req.Fail 500
          resultвЖР(error: вОХDMX.Message вЛД at: вОХDMX.DM)
      :EndTrap
    вИЗ

    вИЗ resultвЖРGetMatch req
      :Access Public
      вОХIOвЖР0
      :If вНђвЙ°lastMatch
          req.Fail 404
          resultвЖР(detail: 'No match has been run yet')
      :Else
          resultвЖРMatchSummary lastMatch
      :EndIf
    вИЗ

    вИЗ resultвЖРGetHistory req;h;frames;s;f
      :Access Public
      вОХIOвЖР0
      :If вНђвЙ°lastMatch
          req.Fail 404
          resultвЖР(detail: 'No match has been run yet')
      :Else
          framesвЖР{(turn: вНµ.turn вЛД bots: вНµ.bots вЛД bullets: вНµ.bullets вЛД thoughts: {6::вНђ вЛД вНµ.thoughts}вНµ)}¬®lastMatch.history
          resultвЖР(
            turns: lastMatch.turn
            done: lastMatch.done
            names: lastMatch.names
            arena: game.Cfg.ARENA
            botRadius: game.Cfg.BOT_RADIUS
            visionRange: game.Cfg.VISION_RANGE
            visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
            botHP: game.Cfg.BOT_HP
            frames: frames
          )
      :EndIf
    вИЗ

    вИЗ resultвЖРListBots req
      :Access Public
      resultвЖРgame.BotLib.List
    вИЗ

    вИЗ resultвЖРUploadBot req;body;author;name;source;avatar
      :Access Public
      вОХIOвЖР0
      :Trap 0
          bodyвЖРreq.Payload
          authorвЖРbody.author
          nameвЖРbody.name
          sourceвЖРbody.source
          avatarвЖР''
          :If 0вЙ†вОХNC'body.avatar'
              avatarвЖРbody.avatar
          :EndIf
          resultвЖРgame.BotLib.Upload author name source avatar
          req.SetStatus 201
      :Else
          req.Fail 400
          resultвЖР(error: вОХDMX.Message)
      :EndTrap
    вИЗ

    вИЗ resultвЖРDeleteBot req;author;name
      :Access Public
      вОХIOвЖР0
      :Trap 6
          authorвЖРreq.PathParams.author
          nameвЖРreq.PathParams.name
          game.BotLib.Delete author name
          resultвЖР(deleted: author,'/',name)
      :Else
          req.Fail 404
          resultвЖР(error: вОХDMX.Message)
      :EndTrap
    вИЗ

    вИЗ resultвЖРMatchSummary m;a;h
      :Access Private
      вОХIOвЖР0
      aвЖРm.bots[;7] вЛД hвЖРm.bots[;5]
      resultвЖР(
        turn: m.turn
        done: m.done
        names: m.names
        alive: a
        hp: h
        turns: вЙҐm.history
      )
    вИЗ

    вИЗ resultвЖРGetConfig req
      :Access Public
      resultвЖР(
        arena: game.Cfg.ARENA
        botSpeed: game.Cfg.BOT_SPEED
        botHP: game.Cfg.BOT_HP
        botRadius: game.Cfg.BOT_RADIUS
        bulletSpeed: game.Cfg.BULLET_SPEED
        bulletDamage: game.Cfg.BULLET_DAMAGE
        visionRange: game.Cfg.VISION_RANGE
        visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
        cooldown: game.Cfg.COOLDOWN
        collisionDamage: game.Cfg.COLLISION_DAMAGE
        collisionBounce: game.Cfg.COLLISION_BOUNCE
        maxTurns: game.Cfg.MAX_TURNS
      )
    вИЗ

    вИЗ savedвЖРSaveCfg
      :Access Private
      savedвЖР(
        ARENA: game.Cfg.ARENA
        BOT_SPEED: game.Cfg.BOT_SPEED
        BOT_HP: game.Cfg.BOT_HP
        BOT_RADIUS: game.Cfg.BOT_RADIUS
        BULLET_SPEED: game.Cfg.BULLET_SPEED
        BULLET_DAMAGE: game.Cfg.BULLET_DAMAGE
        VISION_RANGE: game.Cfg.VISION_RANGE
        VISION_HALF_ANGLE: game.Cfg.VISION_HALF_ANGLE
        COOLDOWN: game.Cfg.COOLDOWN
        COLLISION_DAMAGE: game.Cfg.COLLISION_DAMAGE
        COLLISION_BOUNCE: game.Cfg.COLLISION_BOUNCE
        MAX_TURNS: game.Cfg.MAX_TURNS
      )
    вИЗ

    вИЗ {r}вЖРApplyCfg cfg
      :Access Private
      rвЖРвНђ
      :If 0вЙ†вОХNC'cfg.arena'          вЛД game.Cfg.ARENAвЖРcfg.arena                       вЛД :EndIf
      :If 0вЙ†вОХNC'cfg.botSpeed'       вЛД game.Cfg.BOT_SPEEDвЖРcfg.botSpeed                вЛД :EndIf
      :If 0вЙ†вОХNC'cfg.botHP'          вЛД game.Cfg.BOT_HPвЖРcfg.botHP                      вЛД :EndIf
      :If 0вЙ†вОХNC'cfg.botRadius'      вЛД game.Cfg.BOT_RADIUSвЖРcfg.botRadius              вЛД :EndIf
      :If 0вЙ†вОХNC'cfg.bulletSpeed'    вЛД game.Cfg.BULLET_SPEEDвЖРcfg.bulletSpeed           вЛД :EndIf
      :If 0вЙ†вОХNC'cfg.bulletDamage'   вЛД game.Cfg.BULLET_DAMAGEвЖРcfg.bulletDamage         вЛД :EndIf
      :If 0вЙ†вОХNC'cfg.visionRange'    вЛД game.Cfg.VISION_RANGEвЖРcfg.visionRange           вЛД :EndIf
      :If 0вЙ†вОХNC'cfg.visionHalfAngle' вЛД game.Cfg.VISION_HALF_ANGLEвЖРcfg.visionHalfAngle вЛД :EndIf
      :If 0вЙ†вОХNC'cfg.cooldown'       вЛД game.Cfg.COOLDOWNвЖРcfg.cooldown                  вЛД :EndIf
      :If 0вЙ†вОХNC'cfg.collisionDamage' вЛД game.Cfg.COLLISION_DAMAGEвЖРcfg.collisionDamage  вЛД :EndIf
      :If 0вЙ†вОХNC'cfg.collisionBounce' вЛД game.Cfg.COLLISION_BOUNCEвЖРcfg.collisionBounce  вЛД :EndIf
      :If 0вЙ†вОХNC'cfg.maxTurns'       вЛД game.Cfg.MAX_TURNSвЖРcfg.maxTurns                 вЛД :EndIf
    вИЗ

    вИЗ resultвЖРResetConfig req
      :Access Public
      RestoreCfg defaultCfg
      resultвЖРGetConfig req
    вИЗ

    вИЗ {r}вЖРRestoreCfg saved
      :Access Private
      rвЖРвНђ
      game.Cfg.ARENAвЖРsaved.ARENA
      game.Cfg.BOT_SPEEDвЖРsaved.BOT_SPEED
      game.Cfg.BOT_HPвЖРsaved.BOT_HP
      game.Cfg.BOT_RADIUSвЖРsaved.BOT_RADIUS
      game.Cfg.BULLET_SPEEDвЖРsaved.BULLET_SPEED
      game.Cfg.BULLET_DAMAGEвЖРsaved.BULLET_DAMAGE
      game.Cfg.VISION_RANGEвЖРsaved.VISION_RANGE
      game.Cfg.VISION_HALF_ANGLEвЖРsaved.VISION_HALF_ANGLE
      game.Cfg.COOLDOWNвЖРsaved.COOLDOWN
      game.Cfg.COLLISION_DAMAGEвЖРsaved.COLLISION_DAMAGE
      game.Cfg.COLLISION_BOUNCEвЖРsaved.COLLISION_BOUNCE
      game.Cfg.MAX_TURNSвЖРsaved.MAX_TURNS
    вИЗ

    вИЗ resultвЖРGetRecord req;id;valid;vals;idx;rec
      :Access Public
      вОХIOвЖР0
      (valid vals)вЖРвОХVFI req.PathParams.id
      :If ~вИ®/valid
          req.Fail 400
          resultвЖР(detail: 'Invalid match ID')
          :Return
      :EndIf
      idвЖРвКГvalid/vals
      idxвЖР{вНµ.id}¬®matches
      :If ~idвИКidx
          req.Fail 404
          resultвЖР(detail: 'Match not found')
          :Return
      :EndIf
      recвЖР(idxвН≥id)вКГmatches
      :If вНђвЙ°rec.match
          req.Fail 404
          resultвЖР(detail: 'Match not yet complete')
          :Return
      :EndIf
      resultвЖРgame.Record.Create rec.match rec.names
    вИЗ

    вИЗ resultвЖРReplayRecord req;body;manifest;names;botns;i;ns;warnings;savedCfg;cfg;rec
      :Access Public
      вОХIOвЖР0
      :Trap 0
          bodyвЖРreq.Payload
          manifestвЖРbody
          вНЭ Validate manifest
          warningsвЖРgame.Record.Validate manifest
          вНЭ Save current config and apply manifest config
          savedCfgвЖРSaveCfg
          :Trap 0
              cfgвЖРmanifest.config
              :If 0вЙ†вОХNC'cfg.ARENA'             вЛД game.Cfg.ARENAвЖРcfg.ARENA                         вЛД :EndIf
              :If 0вЙ†вОХNC'cfg.BOT_SPEED'         вЛД game.Cfg.BOT_SPEEDвЖРcfg.BOT_SPEED                 вЛД :EndIf
              :If 0вЙ†вОХNC'cfg.BOT_HP'            вЛД game.Cfg.BOT_HPвЖРcfg.BOT_HP                       вЛД :EndIf
              :If 0вЙ†вОХNC'cfg.BOT_RADIUS'        вЛД game.Cfg.BOT_RADIUSвЖРcfg.BOT_RADIUS               вЛД :EndIf
              :If 0вЙ†вОХNC'cfg.BULLET_SPEED'      вЛД game.Cfg.BULLET_SPEEDвЖРcfg.BULLET_SPEED           вЛД :EndIf
              :If 0вЙ†вОХNC'cfg.BULLET_DAMAGE'     вЛД game.Cfg.BULLET_DAMAGEвЖРcfg.BULLET_DAMAGE         вЛД :EndIf
              :If 0вЙ†вОХNC'cfg.VISION_RANGE'      вЛД game.Cfg.VISION_RANGEвЖРcfg.VISION_RANGE           вЛД :EndIf
              :If 0вЙ†вОХNC'cfg.VISION_HALF_ANGLE' вЛД game.Cfg.VISION_HALF_ANGLEвЖРcfg.VISION_HALF_ANGLE вЛД :EndIf
              :If 0вЙ†вОХNC'cfg.COOLDOWN'          вЛД game.Cfg.COOLDOWNвЖРcfg.COOLDOWN                   вЛД :EndIf
              :If 0вЙ†вОХNC'cfg.COLLISION_DAMAGE'  вЛД game.Cfg.COLLISION_DAMAGEвЖРcfg.COLLISION_DAMAGE    вЛД :EndIf
              :If 0вЙ†вОХNC'cfg.COLLISION_BOUNCE'  вЛД game.Cfg.COLLISION_BOUNCEвЖРcfg.COLLISION_BOUNCE    вЛД :EndIf
              :If 0вЙ†вОХNC'cfg.MAX_TURNS'         вЛД game.Cfg.MAX_TURNSвЖРcfg.MAX_TURNS                 вЛД :EndIf
              вНЭ Resolve bots
              namesвЖР{вНµ.name}¬®manifest.bots
              botnsвЖРвНђ
              :For i :In вН≥вЙҐnames
                  nsвЖРgame.BotLib.Resolve(iвКГnames)
                  botns,вЖРns
              :EndFor
              lastBotNamesвЖРnames
              recвЖРNewMatchRecord names
              lastMatchвЖРmanifest.seed game.Engine.Run botns
              rec.matchвЖРlastMatch
              rec.doneвЖР1
              req.SetStatus 201
              resultвЖР(match: MatchSummary lastMatch вЛД warnings: warnings вЛД id: rec.id)
          :Else
              RestoreCfg savedCfg
              вОХDMX.EM вОХSIGNAL вОХDMX.EN
          :EndTrap
      :Else
          req.Fail 500
          resultвЖР(error: вОХDMX.Message)
      :EndTrap
    вИЗ

    вИЗ {r}вЖРRunMatch args;botns;rec;matchRemotes;rem;finalAlive;finalHP;nBots;frames;alivePerFrame;deathFrames;scores;ranks;idx;dt;match;seed;i;hitLog;myHits;hitsOnMe;j;hitsOnJ;standings;ns
      :Access Private
      rвЖРвНђ
      вОХIOвЖР0
      (botns rec matchRemotes)вЖРargs
      :Trap 0
          вНЭ Inline Engine.Run so rec.match is live during execution
          seedвЖР?2147483646
          вОХRLвЖРseed
          :For i :In вН≥вЙҐbotns
              (iвКГbotns).вОХRLвЖРseed
          :EndFor
          matchвЖРgame.Engine.Init botns
          match.seedвЖРseed
          rec.matchвЖРmatch
          :While ~match.done
              matchвЖРgame.Engine.Tick match
          :EndWhile
          match.history,вЖРвКВ(turn: match.turn вЛД bots: match.bots вЛД bullets: match.bullets вЛД thoughts: match.thoughts)
          lastMatchвЖРmatch
      :Else
          вНЭ Match failed вАФ ensure we don't hang
      :EndTrap
      rec.doneвЖР1
      :If 0вЙ†вОХNC'lastMatch.bots'
          finalAliveвЖРlastMatch.bots[;7]
          finalHPвЖРlastMatch.bots[;5]
          nBotsвЖРвЙҐfinalAlive
          вНЭ Compute death frame for each bot
          framesвЖРlastMatch.history
          alivePerFrameвЖРвЖС{вНµ.bots[;7]}¬®frames
          deathFramesвЖР{вНµвН≥0}¬®вЖУвНЙalivePerFrame
          вНЭ Rank: alive bots by HP (desc), dead bots by survival time (desc)
          scoresвЖР(finalAlive√Ч10000)+(finalAlive√ЧfinalHP)+((1-finalAlive)√ЧdeathFrames)
          ranksвЖР1+вНЛвНЛ-scores
          вНЭ Build standings for done response
          standingsвЖР{вОХIOвЖР0 вЛД nsвЖРвОХNSвНђ вЛД ns.nameвЖРвНЇ вЛД ns.hpвЖРвНµ вЛД ns.rankвЖР(вН≥вЙҐranks)вКГranks вЛД ns}¬®вН®/вЖУ(вЖСlastMatch.names)(finalHP)
          вНЭ Actually build properly вАФ need rank per bot
          standingsвЖРвНђ
          :For idx :In вН≥nBots
              nsвЖРвОХNSвНђ
              ns.nameвЖРвНХidxвКГlastMatch.names
              ns.hpвЖРfinalHP[idx]
              ns.aliveвЖРfinalAlive[idx]
              ns.rankвЖРidxвКГranks
              standings,вЖРns
          :EndFor
          вНЭ Compute per-bot hit/kill stats from hitLog
          hitLogвЖРlastMatch.hitLog
          :For rem :In matchRemotes
              idxвЖРrem.botIndex
              rem.finalHPвЖРfinalHP[idx]
              rem.aliveвЖРfinalAlive[idx]
              rem.totalBotsвЖРnBots
              rem.rankвЖРidxвКГranks
              rem.standingsвЖРstandings
              вНЭ Combat stats
              :If 0<вЙҐhitLog
                  myHitsвЖР(idx={вКГвНµ}¬®hitLog)/hitLog
                  rem.shotsHitвЖРвЙҐmyHits
                  вНЭ Kills: dead bots where my bullet was the last to hit them
                  rem.killsвЖР0
                  :For j :In вНЄ~finalAlive
                      hitsOnJвЖР(j={1вКГвНµ}¬®hitLog)/hitLog
                      :If 0<вЙҐhitsOnJ
                          :If idx=вКГвКГвМљhitsOnJ
                              rem.kills+вЖР1
                          :EndIf
                      :EndIf
                  :EndFor
                  hitsOnMeвЖР(idx={1вКГвНµ}¬®hitLog)/hitLog
                  rem.damageTakenвЖР+/{2вКГвНµ}¬®hitsOnMe
              :Else
                  rem.shotsHitвЖР0
                  rem.killsвЖР0
                  rem.damageTakenвЖР0
              :EndIf
              :If ~rem.alive
                  dtвЖРidxвКГdeathFrames
                  :If dt<вЙҐframes
                      rem.deathTurnвЖР(dtвКГframes).turn
                  :Else
                      rem.deathTurnвЖРlastMatch.turn
                  :EndIf
              :EndIf
              rem.statusвЖР'done'
          :EndFor
      :Else
          :For rem :In matchRemotes
              rem.statusвЖР'done'
          :EndFor
      :EndIf
      SaveMatch rec
    вИЗ

    вИЗ resultвЖРEndMatch req;id;valid;vals;idx;rec
      :Access Public
      вОХIOвЖР0
      (valid vals)вЖРвОХVFI req.PathParams.id
      :If ~вИ®/valid
          req.Fail 400
          resultвЖР(detail: 'Invalid match ID')
          :Return
      :EndIf
      idвЖРвКГvalid/vals
      idxвЖР{вНµ.id}¬®matches
      :If ~idвИКidx
          req.Fail 404
          resultвЖР(detail: 'Match not found')
          :Return
      :EndIf
      recвЖР(idxвН≥id)вКГmatches
      :If вНђвЙ°rec.match
          req.Fail 404
          resultвЖР(detail: 'Match not started')
          :Return
      :EndIf
      :If rec.done
          resultвЖР(detail: 'Match already finished')
          :Return
      :EndIf
      rec.match.doneвЖР1
      resultвЖР(detail: 'Match ending вАФ will complete on next tick')
    вИЗ

    вИЗ recвЖРNewMatchRecord names
      :Access Private
      recвЖРвОХNSвНђ
      rec.idвЖРnextMatchId
      rec.namesвЖРnames
      rec.matchвЖРвНђ
      rec.doneвЖР0
      matches,вЖРrec
      nextMatchIdвЖРnextMatchId+1
    вИЗ

    вИЗ {r}вЖРSaveMatch rec;hist;frames;path;json
      :Access Private
      вОХIOвЖР0
      rвЖРвНђ
      :Trap 0
          framesвЖР{(turn: вНµ.turn вЛД bots: вНµ.bots вЛД bullets: вНµ.bullets вЛД thoughts: {6::вНђ вЛД вНµ.thoughts}вНµ)}¬®rec.match.history
          histвЖРвОХNSвНђ
          hist.idвЖРrec.id
          hist.turnsвЖРrec.match.turn
          hist.doneвЖРrec.match.done
          hist.namesвЖРrec.match.names
          hist.seedвЖРrec.match.seed
          hist.arenaвЖРgame.Cfg.ARENA
          hist.botRadiusвЖРgame.Cfg.BOT_RADIUS
          hist.visionRangeвЖРgame.Cfg.VISION_RANGE
          hist.visionHalfAngleвЖРgame.Cfg.VISION_HALF_ANGLE
          hist.botHPвЖРgame.Cfg.BOT_HP
          hist.framesвЖРframes
          jsonвЖРвОХJSON hist
          pathвЖР'matches/match-',(вНХrec.id),'.json'
          (вКВjson)вОХNPUT path 1
      :Else
          вОХвЖР'SaveMatch failed: ',вОХDMX.Message
      :EndTrap
    вИЗ

    вИЗ resultвЖРListMatches req
      :Access Public
      вОХIOвЖР0
      resultвЖР(matches: {вОХIOвЖР0 вЛД nsвЖРвОХNSвНђ вЛД ns.idвЖРвНµ.id вЛД ns.namesвЖРвНµ.names вЛД ns.doneвЖРвНµ.done вЛД ns.turnsвЖР{вНђвЙ°вНµ:0 вЛД вНµ.turn}вНµ.match вЛД ns}¬®matches)
    вИЗ

    вИЗ resultвЖРGetMatchHistory req;id;valid;vals;idx;rec;frames
      :Access Public
      вОХIOвЖР0
      (valid vals)вЖРвОХVFI req.PathParams.id
      :If ~вИ®/valid
          req.Fail 400
          resultвЖР(detail: 'Invalid match ID')
          :Return
      :EndIf
      idвЖРвКГvalid/vals
      idxвЖР{вНµ.id}¬®matches
      :If ~idвИКidx
          req.Fail 404
          resultвЖР(detail: 'Match not found')
          :Return
      :EndIf
      recвЖР(idxвН≥id)вКГmatches
      :If вНђвЙ°rec.match
          :If ~rec.done
              resultвЖР(detail: 'Match not yet started' вЛД id: id)
          :Else
              req.Fail 500
              resultвЖР(detail: 'Match failed')
          :EndIf
          :Return
      :EndIf
      framesвЖР{(turn: вНµ.turn вЛД bots: вНµ.bots вЛД bullets: вНµ.bullets вЛД thoughts: {6::вНђ вЛД вНµ.thoughts}вНµ)}¬®rec.match.history
      resultвЖР(
        turns: rec.match.turn
        done: rec.match.done
        names: rec.match.names
        arena: game.Cfg.ARENA
        botRadius: game.Cfg.BOT_RADIUS
        visionRange: game.Cfg.VISION_RANGE
        visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
        botHP: game.Cfg.BOT_HP
        frames: frames
      )
    вИЗ

    вИЗ resultвЖРGetSituation req;id;valid;vals;idx;rec;m;bots;i;ns;hitLog;hitsBy;hitsOn;lastHitter
      :Access Public
      вОХIOвЖР0
      (valid vals)вЖРвОХVFI req.PathParams.id
      :If ~вИ®/valid
          req.Fail 400
          resultвЖР(detail: 'Invalid match ID')
          :Return
      :EndIf
      idвЖРвКГvalid/vals
      idxвЖР{вНµ.id}¬®matches
      :If ~idвИКidx
          req.Fail 404
          resultвЖР(detail: 'Match not found')
          :Return
      :EndIf
      recвЖР(idxвН≥id)вКГmatches
      :If вНђвЙ°rec.match
          req.Fail 404
          resultвЖР(detail: 'Match not yet started')
          :Return
      :EndIf
      mвЖРrec.match
      botsвЖРm.bots
      hitLogвЖРm.hitLog
      resultвЖРвОХNSвНђ
      result.turnвЖРm.turn
      result.doneвЖРm.done
      result.botsвЖРвНђ
      :For i :In вН≥вЙҐbots
          nsвЖРвОХNSвНђ
          ns.nameвЖРвНХiвКГm.names
          ns.hpвЖРbots[i;5]
          ns.aliveвЖРbots[i;7]
          ns.xвЖРbots[i;1]
          ns.yвЖРbots[i;2]
          ns.directionвЖРbots[i;3]
          ns.turretвЖРbots[i;4]
          вНЭ Combat stats from hitLog
          :If 0<вЙҐhitLog
              hitsByвЖР(i={вКГвНµ}¬®hitLog)/hitLog
              hitsOnвЖР(i={1вКГвНµ}¬®hitLog)/hitLog
              ns.shotsHitвЖРвЙҐhitsBy
              ns.damageTakenвЖР+/{2вКГвНµ}¬®hitsOn
              ns.damageDealtвЖР+/{2вКГвНµ}¬®hitsBy
              вНЭ Kills: dead bots where I was last to hit
              ns.killsвЖР0
              :For j :In вНЄ~bots[;7]
                  lastHitterвЖР(j={1вКГвНµ}¬®hitLog)/hitLog
                  :If 0<вЙҐlastHitter
                      :If i=вКГвКГвМљlastHitter
                          ns.kills+вЖР1
                      :EndIf
                  :EndIf
              :EndFor
          :Else
              ns.shotsHitвЖР0
              ns.damageTakenвЖР0
              ns.damageDealtвЖР0
              ns.killsвЖР0
          :EndIf
          result.bots,вЖРns
      :EndFor
      вНЭ Bullets: position, heading, owner
      :If 0<вЙҐm.bullets
          result.bulletsвЖР{вОХIOвЖР0 вЛД nsвЖРвОХNSвНђ вЛД ns.xвЖРвНµ[0] вЛД ns.yвЖРвНµ[1] вЛД ns.headingвЖР(180√ЈвЧЛ1)√Ч12вЧЛ(0J1√ЧвНµ[2])+вНµ[3] вЛД ns.ownerвЖРвНµ[4] вЛД ns}¬®вЖУm.bullets
      :Else
          result.bulletsвЖРвНђ
      :EndIf
    вИЗ

    вИЗ remвЖРResolveSlot(slot token);valid;vals;idx
      :Access Private
      вОХIOвЖР0
      (valid vals)вЖРвОХVFIвНХslot
      :If ~вИ®/valid
          remвЖРвНђ
          :Return
      :EndIf
      slotвЖРвКГvalid/vals
      idxвЖР{вНµ.slot}¬®remotes
      :If ~slotвИКidx
          remвЖРвНђ
          :Return
      :EndIf
      remвЖР(idxвН≥slot)вКГremotes
      :If tokenвЙҐrem.secret
          remвЖРвНђ
      :EndIf
    вИЗ

    вИЗ resultвЖРListRemotes req
      :Access Public
      вОХIOвЖР0
      resultвЖР(remotes: {вОХIOвЖР0 вЛД nsвЖРвОХNSвНђ вЛД ns.slotвЖРвНµ.slot вЛД ns.statusвЖРвНµ.status вЛД ns.tickвЖРвНµ.tick вЛД ns}¬®remotes)
    вИЗ

    вИЗ resultвЖРGetRemoteState req;rem;input;vis
      :Access Public
      вОХIOвЖР0
      remвЖРResolveSlot req.PathParams.slot req.PathParams.token
      :If вНђвЙ°rem
          req.Fail 404
          resultвЖР(detail: 'Remote slot not found')
          :Return
      :EndIf
      :Select rem.status
      :Case 'idle'
          req.Fail 404
          resultвЖР(detail: 'Remote not yet started')
      :Case 'done'
          resultвЖРвОХNSвНђ
          result.statusвЖР'done'
          result.turnвЖРrem.tick
          result.hpвЖРrem.finalHP
          result.aliveвЖРrem.alive
          result.rankвЖРrem.rank
          result.totalBotsвЖРrem.totalBots
          :If ¬ѓ1вЙҐrem.deathTurn
              result.deathTurnвЖРrem.deathTurn
          :EndIf
          :If 0вЙ†rem.вОХNC'standings'
              result.standingsвЖРrem.standings
          :EndIf
          :If 0вЙ†rem.вОХNC'shotsHit'
              result.shotsHitвЖРrem.shotsHit
              result.killsвЖРrem.kills
              result.damageTakenвЖРrem.damageTaken
          :EndIf
      :Case 'processing'
          resultвЖР(status: 'processing' вЛД turn: rem.tick)
      :Case 'waiting'
          inputвЖРrem.pendingInput
          resultвЖРвОХNSвНђ
          result.statusвЖР'active'
          result.turnвЖРinput.turn
          result.positionвЖРinput.loc
          result.directionвЖРinput.direction
          result.turretвЖРinput.turret
          result.hpвЖРinput.hp
          result.arenaвЖРinput.arena
          result.configвЖРinput.cfg
          visвЖРinput.visible
          :If 0<вЙҐvis
              result.visibleвЖР{nsвЖРвОХNSвНђ вЛД ns.typeвЖР(вНµ[2])вКГ'rhobot' 'bullet' вЛД ns.distanceвЖРвНµ[0] вЛД ns.offsetвЖРвНµ[1] вЛД ns}¬®вЖУvis
          :Else
              result.visibleвЖРвНђ
          :EndIf
      :EndSelect
    вИЗ

    вИЗ resultвЖРPostRemoteAction req;body;act;rem
      :Access Public
      вОХIOвЖР0
      remвЖРResolveSlot req.PathParams.slot req.PathParams.token
      :If вНђвЙ°rem
          req.Fail 404
          resultвЖР(detail: 'Remote slot not found')
          :Return
      :EndIf
      :If 'waiting'вЙҐrem.status
          :If 'done'вЙ°rem.status
              resultвЖР(status: 'done' вЛД turn: rem.tick)
          :Else
              req.Fail 409
              resultвЖР(detail: 'Remote bot is not waiting for input')
          :EndIf
          :Return
      :EndIf
      bodyвЖРreq.Payload
      actвЖРвОХNSвНђ
      :If 0вЙ†body.вОХNC'direction' вЛД act.directionвЖРbody.direction вЛД :EndIf
      :If 0вЙ†body.вОХNC'turret' вЛД act.turretвЖРbody.turret вЛД :EndIf
      :If 0вЙ†body.вОХNC'fire' вЛД act.fireвЖРbody.fire вЛД :EndIf
      :If 0вЙ†body.вОХNC'speed' вЛД act.speedвЖРbody.speed вЛД :EndIf
      :If 0вЙ†body.вОХNC'thought' вЛД act.thoughtвЖРbody.thought вЛД :EndIf
      act.stateвЖРrem.pendingInput.state
      rem.pendingActionвЖРact
      вОХTPUT rem.token
      resultвЖР(ok: 1 вЛД turn: rem.tick)
    вИЗ

:EndClass
