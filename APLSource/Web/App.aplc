    ‚ąá result‚ÜźStartMatch req;body;names;botns;i;ns;rec;matchRemotes
      :Access Public
      ‚éēIO‚Üź0
      :Trap 0
          body‚Üźreq.Payload
          names‚Üźbody.bots
          ‚ćĚ Apply ephemeral config if provided (persists until server restart)
          :If 0‚Č†‚éēNC'body.config'
              ApplyCfg body.config
          :EndIf
          botns‚Üź‚ć¨
          matchRemotes‚Üź‚ć¨
          :For i :In ‚ć≥‚ČĘnames
              :If 'Remote'‚Č°6‚ÜĎi‚äÉnames
                  ns‚Üźgame.Rhobots.Remote.Create nextSlot
                  ns.botIndex‚Üźi
                  ‚ćĚ Support Remote:Name format for display
                  :If ':'‚ąäi‚äÉnames
                      ns.‚éēDF(1+(':'‚ć≥‚ć®i‚äÉnames))‚Üďi‚äÉnames
                  :EndIf
                  remotes,‚Üźns
                  matchRemotes,‚Üźns
                  nextSlot‚ÜźnextSlot+1
              :Else
                  ns‚Üźgame.BotLib.Resolve(i‚äÉnames)
              :EndIf
              botns,‚Üźns
          :EndFor
          lastBotNames‚Üźnames
          rec‚ÜźNewMatchRecord names
          RunMatch&(botns rec matchRemotes)
          req.SetStatus 202
          result‚Üź‚éēNS‚ć¨
          result.id‚Üźrec.id
          result.status‚Üź'running'
          :If 0<‚ČĘmatchRemotes
              result.remotes‚Üź{‚éēIO‚Üź0 ‚čĄ ns‚Üź‚éēNS‚ć¨ ‚čĄ ns.slot‚Üź‚ćĶ.slot ‚čĄ ns.token‚Üź‚ćĶ.secret ‚čĄ ns}¬®matchRemotes
          :EndIf
      :Else
          req.Fail 500
          result‚Üź(error: ‚éēDMX.Message ‚čĄ at: ‚éēDMX.DM)
      :EndTrap
    ‚ąá

    ‚ąá result‚ÜźGetMatch req
      :Access Public
      ‚éēIO‚Üź0
      :If ‚ć¨‚Č°lastMatch
          req.Fail 404
          result‚Üź(detail: 'No match has been run yet')
      :Else
          result‚ÜźMatchSummary lastMatch
      :EndIf
    ‚ąá

    ‚ąá result‚ÜźGetHistory req;h;frames;s;f
      :Access Public
      ‚éēIO‚Üź0
      :If ‚ć¨‚Č°lastMatch
          req.Fail 404
          result‚Üź(detail: 'No match has been run yet')
      :Else
          frames‚Üź{(turn: ‚ćĶ.turn ‚čĄ bots: ‚ćĶ.bots ‚čĄ bullets: ‚ćĶ.bullets ‚čĄ thoughts: {6::‚ć¨ ‚čĄ ‚ćĶ.thoughts}‚ćĶ)}¬®lastMatch.history
          result‚Üź(
            turns: lastMatch.turn
            done: lastMatch.done
            names: lastMatch.names
            arena: game.Cfg.ARENA
            botRadius: game.Cfg.BOT_RADIUS
            visionRange: game.Cfg.VISION_RANGE
            visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
            botHP: game.Cfg.BOT_HP
            frames: frames
          )
      :EndIf
    ‚ąá

