:Class App
‚çù rhowars web API ‚Äî Stark-based REST server
‚çù
‚çù   app‚Üê‚éïNEW rw.Web.App (StarkClass gameNS)
‚çù   app.Start 8080

    :Field Private router
    :Field Private lastMatch
    :Field Private lastBotNames
    :Field Private game
    :Field Private defaultCfg

    ‚àá Make args;StarkClass
      :Access Public
      :Implements Constructor
      (StarkClass game)‚Üêargs
      lastMatch‚Üê‚ç¨
      lastBotNames‚Üê‚ç¨
      router‚Üê‚éïNEW StarkClass
      router.Handlers‚Üê‚éïTHIS
      router.Info‚Üê(title: 'rhowars' ‚ãÑ version: '0.1.0')
      defaultCfg‚ÜêSaveCfg
      game.BotLib.LoadAll
      '/api/match/record' router.Get 'GetRecord'
      '/api/match/replay' router.Post 'ReplayRecord'
      '/api/match/history' router.Get 'GetHistory'
      '/api/match' router.Post 'StartMatch'
      '/api/match' router.Get 'GetMatch'
      '/api/bots' router.Get 'ListBots'
      '/api/bots' router.Post 'UploadBot'
      '/api/bots/{author}/{name}' router.Delete 'DeleteBot'
      '/api/config' router.Get 'GetConfig'
      '/api/config/reset' router.Post 'ResetConfig'
    ‚àá

    ‚àá Start port
      :Access Public
      router.Start port
    ‚àá

    ‚àá Stop
      :Access Public
      router.Stop
    ‚àá

    ‚àá result‚ÜêStartMatch req;body;names;botns;i;ns
      :Access Public
      ‚éïIO‚Üê0
      :Trap 0
          body‚Üêreq.Payload
          names‚Üêbody.bots
          ‚çù Apply ephemeral config if provided (persists until server restart)
          :If 0‚âÝ‚éïNC'body.config'
              ApplyCfg body.config
          :EndIf
          botns‚Üê‚ç¨
          :For i :In ‚ç≥‚â¢names
              ns‚Üêgame.BotLib.Resolve(i‚äÉnames)
              botns,‚Üêns
          :EndFor
          lastBotNames‚Üênames
          lastMatch‚Üêgame.Engine.Run botns
          req.SetStatus 201
          result‚ÜêMatchSummary lastMatch
      :Else
          req.Fail 500
          result‚Üê(error: ‚éïDMX.Message ‚ãÑ at: ‚éïDMX.DM)
      :EndTrap
    ‚àá

    ‚àá result‚ÜêGetMatch req
      :Access Public
      ‚éïIO‚Üê0
      :If ‚ç¨‚â°lastMatch
          req.Fail 404
          result‚Üê(detail: 'No match has been run yet')
      :Else
          result‚ÜêMatchSummary lastMatch
      :EndIf
    ‚àá

    ‚àá result‚ÜêGetHistory req;h;frames;s;f
      :Access Public
      ‚éïIO‚Üê0
      :If ‚ç¨‚â°lastMatch
          req.Fail 404
          result‚Üê(detail: 'No match has been run yet')
      :Else
          frames‚Üê{(turn: ‚çµ.turn ‚ãÑ bots: ‚çµ.bots ‚ãÑ bullets: ‚çµ.bullets)}¬®lastMatch.history
          result‚Üê(
            turns: lastMatch.turn
            done: lastMatch.done
            names: lastMatch.names
            arena: game.Cfg.ARENA
            botRadius: game.Cfg.BOT_RADIUS
            visionRange: game.Cfg.VISION_RANGE
            visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
            botHP: game.Cfg.BOT_HP
            frames: frames
          )
      :EndIf
    ‚àá

    ‚àá result‚ÜêListBots req
      :Access Public
      result‚Üêgame.BotLib.List
    ‚àá

    ‚àá result‚ÜêUploadBot req;body;author;name;source;avatar
      :Access Public
      ‚éïIO‚Üê0
      :Trap 0
          body‚Üêreq.Payload
          author‚Üêbody.author
          name‚Üêbody.name
          source‚Üêbody.source
          avatar‚Üê''
          :If 0‚âÝ‚éïNC'body.avatar'
              avatar‚Üêbody.avatar
          :EndIf
          result‚Üêgame.BotLib.Upload author name source avatar
          req.SetStatus 201
      :Else
          req.Fail 400
          result‚Üê(error: ‚éïDMX.Message)
      :EndTrap
    ‚àá

    ‚àá result‚ÜêDeleteBot req;author;name
      :Access Public
      ‚éïIO‚Üê0
      :Trap 6
          author‚Üêreq.PathParams.author
          name‚Üêreq.PathParams.name
          game.BotLib.Delete author name
          result‚Üê(deleted: author,'/',name)
      :Else
          req.Fail 404
          result‚Üê(error: ‚éïDMX.Message)
      :EndTrap
    ‚àá

    ‚àá result‚ÜêMatchSummary m;a;h
      :Access Private
      ‚éïIO‚Üê0
      a‚Üêm.bots[;7] ‚ãÑ h‚Üêm.bots[;5]
      result‚Üê(
        turn: m.turn
        done: m.done
        names: m.names
        alive: a
        hp: h
        turns: ‚â¢m.history
      )
    ‚àá

    ‚àá result‚ÜêGetConfig req
      :Access Public
      result‚Üê(
        arena: game.Cfg.ARENA
        botSpeed: game.Cfg.BOT_SPEED
        botHP: game.Cfg.BOT_HP
        botRadius: game.Cfg.BOT_RADIUS
        bulletSpeed: game.Cfg.BULLET_SPEED
        bulletDamage: game.Cfg.BULLET_DAMAGE
        visionRange: game.Cfg.VISION_RANGE
        visionHalfAngle: game.Cfg.VISION_HALF_ANGLE
        cooldown: game.Cfg.COOLDOWN
        collisionDamage: game.Cfg.COLLISION_DAMAGE
        collisionBounce: game.Cfg.COLLISION_BOUNCE
        maxTurns: game.Cfg.MAX_TURNS
      )
    ‚àá

    ‚àá saved‚ÜêSaveCfg
      :Access Private
      saved‚Üê(
        ARENA: game.Cfg.ARENA
        BOT_SPEED: game.Cfg.BOT_SPEED
        BOT_HP: game.Cfg.BOT_HP
        BOT_RADIUS: game.Cfg.BOT_RADIUS
        BULLET_SPEED: game.Cfg.BULLET_SPEED
        BULLET_DAMAGE: game.Cfg.BULLET_DAMAGE
        VISION_RANGE: game.Cfg.VISION_RANGE
        VISION_HALF_ANGLE: game.Cfg.VISION_HALF_ANGLE
        COOLDOWN: game.Cfg.COOLDOWN
        COLLISION_DAMAGE: game.Cfg.COLLISION_DAMAGE
        COLLISION_BOUNCE: game.Cfg.COLLISION_BOUNCE
        MAX_TURNS: game.Cfg.MAX_TURNS
      )
    ‚àá

    ‚àá {r}‚ÜêApplyCfg cfg
      :Access Private
      r‚Üê‚ç¨
      :If 0‚âÝ‚éïNC'cfg.arena'          ‚ãÑ game.Cfg.ARENA‚Üêcfg.arena                       ‚ãÑ :EndIf
      :If 0‚âÝ‚éïNC'cfg.botSpeed'       ‚ãÑ game.Cfg.BOT_SPEED‚Üêcfg.botSpeed                ‚ãÑ :EndIf
      :If 0‚âÝ‚éïNC'cfg.botHP'          ‚ãÑ game.Cfg.BOT_HP‚Üêcfg.botHP                      ‚ãÑ :EndIf
      :If 0‚âÝ‚éïNC'cfg.botRadius'      ‚ãÑ game.Cfg.BOT_RADIUS‚Üêcfg.botRadius              ‚ãÑ :EndIf
      :If 0‚âÝ‚éïNC'cfg.bulletSpeed'    ‚ãÑ game.Cfg.BULLET_SPEED‚Üêcfg.bulletSpeed           ‚ãÑ :EndIf
      :If 0‚âÝ‚éïNC'cfg.bulletDamage'   ‚ãÑ game.Cfg.BULLET_DAMAGE‚Üêcfg.bulletDamage         ‚ãÑ :EndIf
      :If 0‚âÝ‚éïNC'cfg.visionRange'    ‚ãÑ game.Cfg.VISION_RANGE‚Üêcfg.visionRange           ‚ãÑ :EndIf
      :If 0‚âÝ‚éïNC'cfg.visionHalfAngle' ‚ãÑ game.Cfg.VISION_HALF_ANGLE‚Üêcfg.visionHalfAngle ‚ãÑ :EndIf
      :If 0‚âÝ‚éïNC'cfg.cooldown'       ‚ãÑ game.Cfg.COOLDOWN‚Üêcfg.cooldown                  ‚ãÑ :EndIf
      :If 0‚âÝ‚éïNC'cfg.collisionDamage' ‚ãÑ game.Cfg.COLLISION_DAMAGE‚Üêcfg.collisionDamage  ‚ãÑ :EndIf
      :If 0‚âÝ‚éïNC'cfg.collisionBounce' ‚ãÑ game.Cfg.COLLISION_BOUNCE‚Üêcfg.collisionBounce  ‚ãÑ :EndIf
      :If 0‚âÝ‚éïNC'cfg.maxTurns'       ‚ãÑ game.Cfg.MAX_TURNS‚Üêcfg.maxTurns                 ‚ãÑ :EndIf
    ‚àá

    ‚àá result‚ÜêResetConfig req
      :Access Public
      RestoreCfg defaultCfg
      result‚ÜêGetConfig req
    ‚àá

    ‚àá {r}‚ÜêRestoreCfg saved
      :Access Private
      r‚Üê‚ç¨
      game.Cfg.ARENA‚Üêsaved.ARENA
      game.Cfg.BOT_SPEED‚Üêsaved.BOT_SPEED
      game.Cfg.BOT_HP‚Üêsaved.BOT_HP
      game.Cfg.BOT_RADIUS‚Üêsaved.BOT_RADIUS
      game.Cfg.BULLET_SPEED‚Üêsaved.BULLET_SPEED
      game.Cfg.BULLET_DAMAGE‚Üêsaved.BULLET_DAMAGE
      game.Cfg.VISION_RANGE‚Üêsaved.VISION_RANGE
      game.Cfg.VISION_HALF_ANGLE‚Üêsaved.VISION_HALF_ANGLE
      game.Cfg.COOLDOWN‚Üêsaved.COOLDOWN
      game.Cfg.COLLISION_DAMAGE‚Üêsaved.COLLISION_DAMAGE
      game.Cfg.COLLISION_BOUNCE‚Üêsaved.COLLISION_BOUNCE
      game.Cfg.MAX_TURNS‚Üêsaved.MAX_TURNS
    ‚àá

    ‚àá result‚ÜêGetRecord req
      :Access Public
      ‚éïIO‚Üê0
      :If ‚ç¨‚â°lastMatch
          req.Fail 404
          result‚Üê(detail: 'No match has been run yet')
      :Else
          result‚Üêgame.Record.Create lastMatch lastBotNames
      :EndIf
    ‚àá

    ‚àá result‚ÜêReplayRecord req;body;manifest;names;botns;i;ns;warnings;savedCfg;cfg
      :Access Public
      ‚éïIO‚Üê0
      :Trap 0
          body‚Üêreq.Payload
          manifest‚Üêbody
          ‚çù Validate manifest
          warnings‚Üêgame.Record.Validate manifest
          ‚çù Save current config and apply manifest config
          savedCfg‚ÜêSaveCfg
          :Trap 0
              cfg‚Üêmanifest.config
              :If 0‚âÝ‚éïNC'cfg.ARENA'             ‚ãÑ game.Cfg.ARENA‚Üêcfg.ARENA                         ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.BOT_SPEED'         ‚ãÑ game.Cfg.BOT_SPEED‚Üêcfg.BOT_SPEED                 ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.BOT_HP'            ‚ãÑ game.Cfg.BOT_HP‚Üêcfg.BOT_HP                       ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.BOT_RADIUS'        ‚ãÑ game.Cfg.BOT_RADIUS‚Üêcfg.BOT_RADIUS               ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.BULLET_SPEED'      ‚ãÑ game.Cfg.BULLET_SPEED‚Üêcfg.BULLET_SPEED           ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.BULLET_DAMAGE'     ‚ãÑ game.Cfg.BULLET_DAMAGE‚Üêcfg.BULLET_DAMAGE         ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.VISION_RANGE'      ‚ãÑ game.Cfg.VISION_RANGE‚Üêcfg.VISION_RANGE           ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.VISION_HALF_ANGLE' ‚ãÑ game.Cfg.VISION_HALF_ANGLE‚Üêcfg.VISION_HALF_ANGLE ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.COOLDOWN'          ‚ãÑ game.Cfg.COOLDOWN‚Üêcfg.COOLDOWN                   ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.COLLISION_DAMAGE'  ‚ãÑ game.Cfg.COLLISION_DAMAGE‚Üêcfg.COLLISION_DAMAGE    ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.COLLISION_BOUNCE'  ‚ãÑ game.Cfg.COLLISION_BOUNCE‚Üêcfg.COLLISION_BOUNCE    ‚ãÑ :EndIf
              :If 0‚âÝ‚éïNC'cfg.MAX_TURNS'         ‚ãÑ game.Cfg.MAX_TURNS‚Üêcfg.MAX_TURNS                 ‚ãÑ :EndIf
              ‚çù Resolve bots
              names‚Üê{‚çµ.name}¬®manifest.bots
              botns‚Üê‚ç¨
              :For i :In ‚ç≥‚â¢names
                  ns‚Üêgame.BotLib.Resolve(i‚äÉnames)
                  botns,‚Üêns
              :EndFor
              lastBotNames‚Üênames
              lastMatch‚Üêmanifest.seed game.Engine.Run botns
              req.SetStatus 201
              result‚Üê(match: MatchSummary lastMatch ‚ãÑ warnings: warnings)
          :Else
              RestoreCfg savedCfg
              ‚éïDMX.EM ‚éïSIGNAL ‚éïDMX.EN
          :EndTrap
      :Else
          req.Fail 500
          result‚Üê(error: ‚éïDMX.Message)
      :EndTrap
    ‚àá

:EndClass
